@model IEnumerable<ShopQuanAo.Models.QuanTriVien>
@{
    ViewData["Title"] = "Danh sách Quản trị viên";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0 text-primary"><i class="fas fa-user-tie me-2"></i>Nhân Sự Quản Trị</h4>
        <div class="text-muted small mt-1">Quản lý danh sách nhân viên và cấp quyền truy cập hệ thống.</div>
    </div>
    <a asp-action="Create" class="btn btn-primary rounded-pill px-4 py-2 shadow-sm fw-medium">
        <i class="fas fa-plus me-2"></i>Thêm nhân sự
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" style="border-radius: 10px;" role="alert">
        <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="main-card card border-0 mb-5">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted small text-uppercase">
                    <tr>
                        <th class="border-0 ps-4">Hồ sơ nhân sự</th>
                        <th class="border-0 text-center">Chức Vụ</th>
                        <th class="border-0">Tài khoản (Đăng nhập)</th>
                        <th class="border-0 text-center">Ngày vào làm</th>
                        <th class="border-0 text-end pe-4">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center">
                                        <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(item.HoTen)&background=e0f3ff&color=3f6ad8&rounded=true"
                                             class="rounded-circle shadow-sm me-3 border" style="width: 45px; height: 45px;" alt="Avatar" />
                                        <div>
                                            <div class="fw-bold text-dark fs-6">@item.HoTen</div>
                                            <div class="text-muted small"><i class="fas fa-phone-alt me-1"></i> @item.SoDienThoai</div>
                                        </div>
                                    </div>
                                </td>
                                
                                <td class="text-center">
                                    <span class="badge rounded-pill bg-info bg-opacity-10 text-info border border-info border-opacity-25 px-3 py-2 fw-bold shadow-sm">
                                        @item.ChucVu
                                    </span>
                                </td>

                                <td>
                                    <div class="fw-bold text-primary"><i class="fas fa-shield-alt me-1"></i> @(item.TaiKhoan?.TenDangNhap ?? "Chưa có")</div>
                                    <div class="text-muted small"><i class="fas fa-envelope me-1"></i> @(item.TaiKhoan?.Email ?? "Chưa cập nhật")</div>
                                </td>
                                
                                <td class="text-center text-muted">
                                    @item.NgayVaoLam.ToString("dd/MM/yyyy")
                                </td>
                                
                                <td class="text-end pe-4">
                                    <div class="btn-group shadow-sm" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.MaTK" class="btn btn-sm btn-light text-primary border" data-bs-toggle="tooltip" title="Cập nhật hồ sơ">
                                            <i class="fas fa-pen"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.MaTK" class="btn btn-sm btn-light text-danger border" data-bs-toggle="tooltip" title="Xóa nhân sự">
                                            <i class="fas fa-user-minus"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <div class="d-inline-flex align-items-center justify-content-center bg-light rounded-circle mb-3" style="width: 80px; height: 80px;">
                                    <i class="fas fa-users-cog fa-2x text-muted opacity-50"></i>
                                </div>
                                <h6 class="fw-bold text-dark">Chưa có nhân sự nào</h6>
                                <p class="text-muted small mb-0">Hệ thống cần ít nhất 1 tài khoản Quản trị viên để hoạt động.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        })
    </script>
}