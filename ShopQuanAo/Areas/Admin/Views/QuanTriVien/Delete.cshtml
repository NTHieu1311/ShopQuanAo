@model ShopQuanAo.Models.QuanTriVien
@{
    ViewData["Title"] = "Xóa Quản trị viên";
}

<div class="row justify-content-center align-items-center" style="min-height: 60vh;">
    <div class="col-md-8 col-lg-6">
        
        <div class="main-card card border-0">
            <div class="card-body p-4 p-md-5">
                
                <div class="text-center mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center bg-danger bg-opacity-10 rounded-circle mb-3" style="width: 80px; height: 80px;">
                        <i class="fas fa-user-minus fa-2x text-danger"></i>
                    </div>
                    <h4 class="fw-bold text-dark">Xác nhận xóa nhân sự?</h4>
                    <p class="text-muted">Hành động này tương đương với việc cho nhân sự nghỉ việc.</p>
                </div>
                
                <div class="bg-light p-4 rounded-4 mb-4 border-start border-danger border-4">
                    <div class="d-flex align-items-center mb-3 pb-3 border-bottom">
                        <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(Model.HoTen)&background=fff&color=d0184d&rounded=true"
                             class="rounded-circle shadow-sm me-3" style="width: 50px; height: 50px;" alt="Avatar" />
                        <div>
                            <h5 class="fw-bold text-dark mb-0">@Model.HoTen</h5>
                            <span class="badge bg-dark mt-1">@Model.ChucVu</span>
                        </div>
                    </div>
                    <p class="mb-2"><strong class="text-muted">Ngày vào làm:</strong> <span class="fw-medium">@Model.NgayVaoLam.ToString("dd/MM/yyyy")</span></p>
                    <p class="mb-0"><strong class="text-muted">Tài khoản liên kết:</strong> <span class="fw-bold text-primary">@Model.TaiKhoan?.TenDangNhap</span></p>
                </div>

                <div class="alert alert-warning border-0 bg-warning bg-opacity-10 text-dark p-3 rounded-3 mb-4 d-flex">
                    <i class="fas fa-exclamation-triangle text-danger mt-1 me-3 fa-lg"></i>
                    <div class="small">
                        <strong>Lưu ý bảo mật:</strong> Xóa hồ sơ này sẽ đồng thời <strong class="text-danger">xóa vĩnh viễn</strong> tài khoản đăng nhập tương ứng khỏi hệ thống. Người này sẽ không thể truy cập vào trang Admin được nữa.
                    </div>
                </div>

                <form asp-action="Delete" class="d-flex justify-content-center align-items-center mt-4 border-top pt-4">
                    <input type="hidden" asp-for="MaTK" />
                    
                    <a asp-action="Index" class="btn btn-light fw-bold px-4 me-3">Hủy bỏ</a>
                    <button type="submit" class="btn btn-danger px-5 py-2 fw-bold shadow-sm" style="border-radius: 8px;">
                        <i class="fas fa-trash-alt me-2"></i> Xác nhận Xóa
                    </button>
                </form>

            </div>
        </div>
    </div>
</div>