@model ShopQuanAo.Models.PhuongThucThanhToan
@{
    ViewData["Title"] = "Sửa PT Thanh Toán";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0 text-primary"><i class="fas fa-edit me-2"></i>Chỉnh Sửa Cổng Thanh Toán</h4>
        <div class="text-muted small mt-1">Đang chỉnh sửa: <strong class="text-dark">@Model.TenPhuongThuc</strong></div>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm fw-medium">
        <i class="fas fa-arrow-left me-2"></i>Quay lại danh sách
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <form asp-action="Edit">
            <input type="hidden" asp-for="MaPT" />
            <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>
            
            <div class="main-card card border-0 mb-4">
                <div class="card-body p-4 p-md-5">
                    
                    <div class="mb-4">
                        <label asp-for="TenPhuongThuc" class="form-label fw-bold">Tên phương thức <span class="text-danger">*</span></label>
                        <input asp-for="TenPhuongThuc" class="form-control form-control-lg bg-light border-0" required />
                    </div>

                    <div class="mb-4">
                        <label asp-for="MoTa" class="form-label fw-bold">Mô tả hướng dẫn cho khách</label>
                        <textarea asp-for="MoTa" class="form-control bg-light border-0" rows="3"></textarea>
                    </div>

                    <div class="mb-5 border-top pt-4">
                        <label asp-for="TrangThai" class="form-label fw-bold">Trạng thái áp dụng</label>
                        <select asp-for="TrangThai" class="form-select form-select-lg bg-light border-0">
                            <option value="1">🟢 Hoạt động (Khách có thể chọn)</option>
                            <option value="0">🔴 Tạm ngưng bảo trì</option>
                        </select>
                    </div>

                    <div class="d-flex justify-content-end align-items-center">
                        <a asp-action="Index" class="btn btn-light fw-bold px-4 me-3">Hủy bỏ</a>
                        <button type="submit" class="btn btn-warning text-dark px-5 py-2 fw-bold shadow-sm" style="border-radius: 8px;">
                            <i class="fas fa-save me-2"></i> Cập Nhật
                        </button>
                    </div>

                </div>
            </div>
        </form>
    </div>
</div>