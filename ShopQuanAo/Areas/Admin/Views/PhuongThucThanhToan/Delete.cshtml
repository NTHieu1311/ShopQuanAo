@model ShopQuanAo.Models.PhuongThucThanhToan
@{
    ViewData["Title"] = "Xóa PT Thanh Toán";
}

<div class="card shadow border-0 col-md-6 mx-auto mt-5 border-danger border-top border-4 text-center p-4">
    <i class="fas fa-exclamation-triangle fa-3x text-danger mb-3"></i>
    <h4 class="fw-bold">Xác nhận xóa?</h4>
    <p class="fs-5 mt-3">Phương thức: <strong class="text-primary">@Model.TenPhuongThuc</strong></p>
    
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger mt-3">@TempData["ErrorMessage"]</div>
    }

    <form asp-action="Delete" class="mt-4">
        <input type="hidden" asp-for="MaPT" />
        <a asp-action="Index" class="btn btn-secondary px-4 me-2">Hủy</a>
        <button type="submit" class="btn btn-danger px-4">Xác nhận Xóa</button>
    </form>
</div>