<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Quản Trị Hệ Thống</title>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <style>
            /* PHONG CÁCH ARCHITECT-UI HIỆN ĐẠI */
            body {
                font-family: 'Poppins', sans-serif;
                background-color: #f1f4f6; /* Nền xám nhạt */
                color: #495057;
                margin: 0;
                padding-top: 60px; /* Chừa chỗ cho Header cố định */
            }

            /* --- HEADER (THANH TRÊN CÙNG) --- */
            .app-header {
                background: #ffffff;
                height: 60px;
                box-shadow: 0 0.46875rem 2.1875rem rgba(4, 9, 20, 0.03), 0 0.9375rem 1.40625rem rgba(4, 9, 20, 0.03);
                display: flex;
                align-items: center;
                justify-content: space-between;
                padding: 0 1.5rem;
                position: fixed;
                top: 0;
                left: 0;
                right: 0;
                z-index: 1030;
            }

            .header-logo {
                width: 250px;
                font-weight: 800;
                font-size: 1.2rem;
                color: #3f6ad8;
                text-decoration: none;
                letter-spacing: 1px;
                display: flex;
                align-items: center;
            }

                .header-logo i {
                    font-size: 1.5rem;
                    margin-right: 10px;
                }

            /* --- SIDEBAR (THANH BÊN TRÁI MÀU TRẮNG) --- */
            .app-sidebar {
                width: 250px;
                background: #ffffff;
                position: fixed;
                top: 60px;
                bottom: 0;
                left: 0;
                z-index: 1000;
                box-shadow: 7px 0 60px rgba(0,0,0,0.05);
                overflow-y: auto;
                transition: all 0.3s;
            }

                .app-sidebar.toggled {
                    left: -250px;
                }

                .app-sidebar .nav-title {
                    color: #3f6ad8;
                    font-size: 0.75rem;
                    font-weight: 700;
                    text-transform: uppercase;
                    padding: 1.5rem 1.5rem 0.5rem;
                    opacity: 0.6;
                }

                .app-sidebar .nav-link {
                    color: #343a40;
                    padding: 0.7rem 1.5rem;
                    font-weight: 500;
                    display: flex;
                    align-items: center;
                    transition: all 0.3s;
                    border-radius: 8px;
                    margin: 0.2rem 1rem;
                    text-decoration: none;
                }

                    .app-sidebar .nav-link i {
                        width: 30px;
                        font-size: 1.1rem;
                        color: #a3a8b1;
                        transition: all 0.3s;
                    }

                    .app-sidebar .nav-link:hover, .app-sidebar .nav-link.active {
                        background: #e0f3ff;
                        color: #3f6ad8;
                    }

                        .app-sidebar .nav-link:hover i, .app-sidebar .nav-link.active i {
                            color: #3f6ad8;
                        }

            /* --- MAIN CONTENT --- */
            .app-main {
                margin-left: 250px;
                padding: 30px;
                transition: all 0.3s;
                min-height: calc(100vh - 60px);
                display: flex;
                flex-direction: column;
            }

                .app-main.expanded {
                    margin-left: 0;
                }

            /* Tùy chỉnh Nút bấm Sidebar & Tìm kiếm */
            #sidebarToggleTop {
                background: transparent;
                border: none;
                color: #a3a8b1;
                font-size: 1.2rem;
                cursor: pointer;
                margin-right: 20px;
                transition: 0.2s;
            }

                #sidebarToggleTop:hover {
                    color: #3f6ad8;
                }

            /* Custom Card giống ArchitectUI */
            .card {
                border: none;
                border-radius: 12px;
                box-shadow: 0 0.46875rem 2.1875rem rgba(4,9,20,0.03), 0 0.9375rem 1.40625rem rgba(4,9,20,0.03);
            }
    </style>
</head>

<body>
    <header class="app-header">
        <div class="d-flex align-items-center">
            <a href="/Admin" class="header-logo">
                <i class="fas fa-layer-group"></i> ADMIN PRO
            </a>
            <button id="sidebarToggleTop">
                <i class="fa-solid fa-bars-staggered"></i>
            </button>

            @{
                var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
                bool showSearchBar = false;
                var searchAction = "";
                var searchPlaceholder = "";

                if (currentController == "DonHang")
                {
                    showSearchBar = true;
                    searchAction = "/Admin/DonHang/Index";
                    searchPlaceholder = "Tìm mã đơn (VD: 1537) hoặc SĐT...";
                }
                else if (currentController == "KhachHang")
                {
                    showSearchBar = true;
                    searchAction = "/Admin/KhachHang/Index";
                    searchPlaceholder = "Tìm tên, SĐT hoặc Email khách...";
                }
                else if (currentController == "SanPham")
                {
                    showSearchBar = true;
                    searchAction = "/Admin/SanPham/Index";
                    searchPlaceholder = "Tìm tên sản phẩm...";
                }
            }

            @if (showSearchBar)
            {
                <form action="@searchAction" method="get" class="d-none d-md-flex align-items-center ms-4">
                    <div class="input-group" style="width: 350px;">
                        <input type="text" name="searchKeyword" class="form-control bg-light border-0" placeholder="@searchPlaceholder" value="@ViewBag.SearchKeyword" style="border-radius: 20px 0 0 20px; padding-left: 20px;">
                        <button class="btn btn-light bg-light border-0" type="submit" style="border-radius: 0 20px 20px 0; color: #3f6ad8;">
                            <i class="fas fa-search"></i>
                        </button>
                    </div>
                </form>
            }
        </div>

        <div class="d-flex align-items-center">
            <div class="dropdown">
                <a class="nav-link d-flex align-items-center" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                    <div class="text-end me-3 d-none d-md-block">
                        <div class="fw-bold text-dark" style="font-size: 0.9rem;">Nguyễn Thành Hiếu</div>
                        <div class="text-muted" style="font-size: 0.75rem;">Giám Đốc</div>
                    </div>
                    <img class="rounded-circle shadow-sm" src="https://ui-avatars.com/api/?name=Thanh+Hieu&background=3f6ad8&color=fff" alt="Admin Avatar" width="40">
                </a>
                <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-3" style="border-radius: 12px;">
                    <li><a class="dropdown-item py-2" href="/Admin/TaiKhoan/HoSo"><i class="fas fa-user fa-sm fa-fw me-2 text-muted"></i> Hồ sơ</a></li>
                    <li><a class="dropdown-item py-2" href="#"><i class="fas fa-cogs fa-sm fa-fw me-2 text-muted"></i> Cài đặt</a></li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <form asp-controller="TaiKhoan" asp-action="Logout" asp-area="" method="post" class="m-0 p-0">
                            <button type="submit" class="dropdown-item py-2 text-danger fw-bold border-0 bg-transparent w-100 text-start">
                                <i class="fas fa-sign-out-alt fa-sm fa-fw me-2"></i> Đăng xuất
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </header>

    <nav class="app-sidebar" id="sidebar">
        <ul class="nav flex-column mt-3 list-unstyled">
            <li class="nav-item">
                <a class="nav-link" href="/Admin/Home/Index">
                    <i class="fas fa-fw fa-tachometer-alt"></i> <span>Tổng Quan</span>
                </a>
            </li>
            
            <li class="nav-title">Sản phẩm & Cửa hàng</li>
            <li class="nav-item">
                <a class="nav-link" href="/Admin/DanhMuc">
                    <i class="fas fa-fw fa-tags"></i> <span>Quản lý Danh Mục</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/Admin/SanPham">
                    <i class="fas fa-fw fa-tshirt"></i> <span>Quản lý Sản Phẩm</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/Admin/BienTheSanPham">
                    <i class="fas fa-fw fa-cubes"></i> <span>Kho & Biến thể</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/Admin/DanhGia">
                    <i class="fas fa-fw fa-star"></i> <span>Đánh Giá Khách Hàng</span>
                </a>
            </li>

            <li class="nav-title">Kinh Doanh</li>
            <li class="nav-item">
                <a class="nav-link" href="/Admin/DonHang">
                    <i class="fas fa-fw fa-clipboard-list"></i> <span>Xử lý Đơn Hàng</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/Admin/KhachHang">
                    <i class="fas fa-fw fa-users"></i> <span>Tệp Khách Hàng</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/Admin/PhuongThucThanhToan">
                    <i class="fas fa-fw fa-credit-card"></i> <span>Cổng Thanh Toán</span>
                </a>
            </li>

            <li class="nav-title">Hệ Thống</li>
            <li class="nav-item">
                <a class="nav-link" href="/Admin/TaiKhoan">
                    <i class="fas fa-fw fa-user-shield"></i> <span>Tất cả Tài Khoản</span>
                </a>
            </li>
            <li class="nav-item">
                <a class="nav-link" href="/Admin/QuanTriVien">
                    <i class="fas fa-fw fa-user-tie"></i> <span>Nhân sự Quản Trị</span>
                </a>
            </li>
        </ul>
    </nav>

    <main class="app-main" id="mainContent">
        @if (TempData["Success"] != null)
        {
            <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm" style="border-radius: 10px;" role="alert">
                <i class="fas fa-check-circle me-2"></i> @TempData["Success"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }
        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm" style="border-radius: 10px;" role="alert">
                <i class="fas fa-exclamation-triangle me-2"></i> @TempData["Error"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        @RenderBody()

        <footer class="mt-auto pt-4 pb-2 text-center text-muted small fw-medium">
            Bản quyền &copy; FASHION STORE ADMIN 2026 - Phát triển bởi Nguyễn Thành Hiếu
        </footer>
    </main>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    
    <script>
        document.addEventListener("DOMContentLoaded", function() {
        // Nút bấm thu gọn menu
        const toggleBtn = document.getElementById("sidebarToggleTop");
        const sidebar = document.getElementById("sidebar");
        const mainContent = document.getElementById("mainContent");
            
        toggleBtn.addEventListener("click", function() {
        sidebar.classList.toggle("toggled");
        mainContent.classList.toggle("expanded");
        });

        // Tự động active menu chuẩn xác (giữ nguyên logic của bạn)
        const currentPath = window.location.pathname;
        const navLinks = document.querySelectorAll('#sidebar .nav-link');
        navLinks.forEach(link => {
        if(currentPath.includes(link.getAttribute('href')) && link.getAttribute('href') !== '/Admin') {
        link.classList.add('active');
        } else if (currentPath === '/Admin' && link.getAttribute('href') === '/Admin/Home/Index') {
        link.classList.add('active'); // Xử lý riêng cho trang chủ
        }
        });
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>