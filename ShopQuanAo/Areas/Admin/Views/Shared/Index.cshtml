@{
    ViewData["Title"] = "Bảng Điều Khiển (Dashboard)";
}

<div class="row">
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-0 shadow-sm rounded-3 h-100 py-2" style="border-left: 5px solid #28a745 !important;">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-success text-uppercase mb-1">Doanh thu (Tháng này)</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.TongDoanhThu VNĐ</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-dollar-sign fa-2x text-muted opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-0 shadow-sm rounded-3 h-100 py-2" style="border-left: 5px solid #007bff !important;">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-primary text-uppercase mb-1">Đơn hàng mới</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.DonHangMoi</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-clipboard-list fa-2x text-muted opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-0 shadow-sm rounded-3 h-100 py-2" style="border-left: 5px solid #17a2b8 !important;">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-info text-uppercase mb-1">Tổng Khách Hàng</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.KhachHang</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-users fa-2x text-muted opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-0 shadow-sm rounded-3 h-100 py-2" style="border-left: 5px solid #dc3545 !important;">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-danger text-uppercase mb-1">Sản phẩm sắp hết</div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">@ViewBag.SanPhamTon</div>
                    </div>
                    <div class="col-auto">
                        <i class="fas fa-exclamation-triangle fa-2x text-muted opacity-50"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card border-0 shadow-sm rounded-3 mt-4">
    <div class="card-header bg-white py-3 d-flex flex-row align-items-center justify-content-between">
        <h6 class="m-0 font-weight-bold text-primary">Đơn hàng gần đây nhất</h6>
    </div>
    <div class="card-body">
        <p class="text-muted">Chưa có dữ liệu đơn hàng thật. Bạn sẽ kết nối Database vào đây sau.</p>
    </div>
</div>