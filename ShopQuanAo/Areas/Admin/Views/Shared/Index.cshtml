@{
    ViewData["Title"] = "Bảng Điều Khiển (Dashboard)";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0">Tổng quan kinh doanh</h4>
        <div class="text-muted small">Cập nhật dữ liệu thời gian thực từ hệ thống.</div>
    </div>
    <button class="btn btn-primary shadow-sm"><i class="fas fa-download me-2"></i>Xuất báo cáo</button>
</div>

<div class="row">
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card main-card h-100 border-0">
            <div class="card-body p-4 d-flex align-items-center">
                <div class="flex-grow-1">
                    <div class="text-muted text-uppercase small fw-bold mb-2">Doanh thu (Tháng này)</div>
                    <h4 class="fw-bold mb-0 text-success">@ViewBag.TongDoanhThu <span class="fs-6 text-muted">VNĐ</span></h4>
                </div>
                <div class="ms-auto">
                    <div class="bg-success text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 55px; height: 55px;">
                        <i class="fas fa-dollar-sign fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card main-card h-100 border-0">
            <div class="card-body p-4 d-flex align-items-center">
                <div class="flex-grow-1">
                    <div class="text-muted text-uppercase small fw-bold mb-2">Đơn hàng mới</div>
                    <h4 class="fw-bold mb-0 text-primary">@ViewBag.DonHangMoi <span class="fs-6 text-muted">Đơn</span></h4>
                </div>
                <div class="ms-auto">
                    <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 55px; height: 55px;">
                        <i class="fas fa-clipboard-list fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card main-card h-100 border-0">
            <div class="card-body p-4 d-flex align-items-center">
                <div class="flex-grow-1">
                    <div class="text-muted text-uppercase small fw-bold mb-2">Tổng Khách Hàng</div>
                    <h4 class="fw-bold mb-0 text-info">@ViewBag.KhachHang <span class="fs-6 text-muted">Người</span></h4>
                </div>
                <div class="ms-auto">
                    <div class="bg-info text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 55px; height: 55px;">
                        <i class="fas fa-users fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card main-card h-100 border-0">
            <div class="card-body p-4 d-flex align-items-center">
                <div class="flex-grow-1">
                    <div class="text-muted text-uppercase small fw-bold mb-2">Sản phẩm sắp hết</div>
                    <h4 class="fw-bold mb-0 text-danger">@ViewBag.SanPhamTon <span class="fs-6 text-muted">Mã SP</span></h4>
                </div>
                <div class="ms-auto">
                    <div class="bg-danger text-white rounded-circle d-flex align-items-center justify-content-center shadow-sm" style="width: 55px; height: 55px;">
                        <i class="fas fa-exclamation-triangle fs-4"></i>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card main-card border-0 mt-2">
    <div class="card-header bg-white pt-4 pb-3 px-4 border-bottom-0 d-flex justify-content-between align-items-center">
        <h5 class="fw-bold mb-0 text-primary"><i class="fas fa-box me-2"></i>Đơn hàng gần đây nhất</h5>
        <a href="/Admin/DonHang" class="btn btn-sm btn-outline-primary rounded-pill px-3">Xem tất cả</a>
    </div>
    <div class="card-body px-4 pb-4">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted">
                    <tr>
                        <th class="border-0">Mã Đơn</th>
                        <th class="border-0">Khách Hàng</th>
                        <th class="border-0">Ngày Đặt</th>
                        <th class="border-0 text-center">Tổng Tiền</th>
                        <th class="border-0 text-center">Trạng Thái</th>
                        <th class="border-0 text-end">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td colspan="6" class="text-center py-5">
                            <div class="text-muted opacity-50 mb-3">
                                <i class="fas fa-folder-open fa-3x"></i>
                            </div>
                            <h6 class="fw-bold">Chưa có đơn hàng nào</h6>
                            <p class="small text-muted mb-0">Dữ liệu đơn hàng thật sẽ hiển thị tại đây sau khi bạn kết nối Database.</p>
                        </td>
                    </tr>
                </tbody>
            </table>
        </div>
    </div>
</div>