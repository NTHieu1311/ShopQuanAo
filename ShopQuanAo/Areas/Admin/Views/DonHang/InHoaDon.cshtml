@model ShopQuanAo.Models.DonHang
@{
    // Tắt Layout chung của Admin để trang in trắng tinh giống tờ A4
    Layout = null; 
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hóa Đơn - #@Model.MaDH - Fashion Store</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@300;400;500;700&display=swap" rel="stylesheet">
    
    <style>
        body {
            background-color: #e9ecef; 
            font-family: 'Roboto', sans-serif; /* Font chuẩn cho in ấn hóa đơn */
            color: #212529;
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
        }

        /* KHUNG GIẤY A4 TRÊN MÀN HÌNH MÁY TÍNH */
        .invoice-box {
            max-width: 21cm; /* Chiều rộng chuẩn A4 */
            min-height: 29.7cm; /* Chiều cao chuẩn A4 */
            margin: 40px auto;
            padding: 2cm;
            background: #fff;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1); 
            border-radius: 4px;
        }

        .invoice-header {
            border-bottom: 2px solid #343a40;
            padding-bottom: 20px;
            margin-bottom: 30px;
        }

        .table-invoice th {
            background-color: #f8f9fa !important;
            color: #343a40;
            font-weight: 700;
            text-transform: uppercase;
            font-size: 0.85rem;
            border-bottom: 2px solid #dee2e6;
        }

        .table-invoice td, .table-invoice th {
            vertical-align: middle;
            padding: 12px;
        }

        .info-box {
            background-color: #f8f9fa;
            border-left: 4px solid #3f6ad8; /* Màu nhấn thương hiệu */
            padding: 1.5rem;
            border-radius: 0 8px 8px 0;
        }

        /* LỆNH CSS CHỈ KÍCH HOẠT KHI NHẤN NÚT IN (Ctrl+P) */
        @@media print {
            body { background-color: #fff; margin: 0; }
            .invoice-box { 
                max-width: 100%;
                min-height: auto;
                margin: 0; 
                padding: 1cm; 
                box-shadow: none; 
                border: none;
                border-radius: 0;
            }
            .no-print { display: none !important; }
            @@page { margin: 1cm; size: A4 portrait; }
        }
    </style>
</head>
<body>

    <div class="text-center mt-4 mb-3 no-print sticky-top bg-light py-3 border-bottom shadow-sm">
        <button onclick="window.print()" class="btn btn-primary btn-lg fw-bold me-3 px-5 rounded-pill shadow">
            <i class="fas fa-print me-2"></i> TIẾN HÀNH IN (PDF)
        </button>
        <button onclick="window.close()" class="btn btn-outline-dark btn-lg fw-bold px-4 rounded-pill">
            <i class="fas fa-times me-2"></i> Đóng
        </button>
    </div>

    <div class="invoice-box" id="invoice">
        
        <div class="row invoice-header align-items-center">
            <div class="col-7">
                <h2 class="fw-bolder text-primary mb-3" style="letter-spacing: 1px;">
                    <i class="fas fa-layer-group me-2"></i>FASHION STORE
                </h2>
                <div class="text-muted small">
                    <p class="mb-1"><i class="fas fa-map-marker-alt me-2 text-dark"></i> 123 Đường Tôn Đức Thắng, TP. Long Xuyên, An Giang</p>
                    <p class="mb-1"><i class="fas fa-phone-alt me-2 text-dark"></i> Hotline: 0909.123.456</p>
                    <p class="mb-0"><i class="fas fa-envelope me-2 text-dark"></i> Email: contact@fashionstore.vn</p>
                </div>
            </div>
            <div class="col-5 text-end">
                <h1 class="fw-bold" style="color: #343a40; letter-spacing: 2px;">HÓA ĐƠN</h1>
                <h5 class="mb-2 fw-bold">Mã Số: <span class="text-danger">#@Model.MaDH.ToString("D5")</span></h5>
                <p class="mb-0 text-muted small">Ngày xuất: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
            </div>
        </div>

        <div class="row mb-5">
            <div class="col-12">
                <div class="info-box">
                    <h6 class="fw-bold text-uppercase mb-3" style="color: #3f6ad8;">Thông tin khách hàng</h6>
                    <div class="row">
                        <div class="col-md-6">
                            <p class="mb-2"><strong>Người nhận:</strong> @Model.TenNguoiNhan</p>
                            <p class="mb-0"><strong>Số điện thoại:</strong> @Model.SDTNguoiNhan</p>
                        </div>
                        <div class="col-md-6">
                            <p class="mb-2"><strong>Ngày đặt hàng:</strong> @Model.NgayDat.ToString("dd/MM/yyyy HH:mm")</p>
                            <p class="mb-0"><strong>Thanh toán:</strong> Thu tiền khi nhận hàng (COD)</p>
                        </div>
                        <div class="col-12 mt-3 pt-3 border-top">
                            <p class="mb-0"><strong>Địa chỉ giao:</strong> @Model.DiaChiGiao</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <table class="table table-bordered table-invoice mb-4">
            <thead>
                <tr>
                    <th class="text-center" width="5%">STT</th>
                    <th width="40%">Tên Sản Phẩm</th>
                    <th class="text-center" width="15%">Phân loại</th>
                    <th class="text-center" width="10%">SL</th>
                    <th class="text-end" width="15%">Đơn Giá</th>
                    <th class="text-end" width="15%">Thành Tiền</th>
                </tr>
            </thead>
            <tbody>
                @{ int stt = 1; }
                @if (Model.ChiTietDonHangs != null && Model.ChiTietDonHangs.Any())
                {
                    foreach (var ct in Model.ChiTietDonHangs)
                    {
                        <tr>
                            <td class="text-center">@stt</td>
                            <td class="fw-bold">@ct.BienTheSanPham.SanPham.TenSP</td>
                            <td class="text-center text-muted">@ct.BienTheSanPham.MauSac / @ct.BienTheSanPham.KichThuoc</td>
                            <td class="text-center fw-bold">@ct.SoLuong</td>
                            <td class="text-end">@ct.BienTheSanPham.SanPham.GiaBan.ToString("#,##0") đ</td>
                            <td class="text-end fw-bold">@((ct.SoLuong * ct.BienTheSanPham.SanPham.GiaBan).ToString("#,##0")) đ</td>
                        </tr>
                        stt++;
                    }
                }
            </tbody>
        </table>

        <div class="row mb-5">
            <div class="col-md-5 offset-md-7">
                <table class="table table-borderless table-sm">
                    <tr>
                        <td class="text-end text-muted">Cộng tiền hàng:</td>
                        <td class="text-end fw-bold" width="35%">@Model.TongTien.ToString("#,##0") đ</td>
                    </tr>
                    <tr class="border-bottom">
                        <td class="text-end text-muted pb-2">Phí vận chuyển:</td>
                        <td class="text-end fw-bold pb-2">0 đ</td>
                    </tr>
                    <tr>
                        <td class="text-end fw-bold fs-5 pt-3 align-middle">TỔNG CỘNG:</td>
                        <td class="text-end fw-bolder text-danger fs-4 pt-3 align-middle">@Model.TongTien.ToString("#,##0") đ</td>
                    </tr>
                </table>
            </div>
        </div>

        <div class="row mt-4 pt-3 text-center">
            <div class="col-6">
                <p class="fw-bold mb-1">Khách hàng</p>
                <p class="text-muted fst-italic small mb-5">(Ký, ghi rõ họ tên)</p>
                <div style="height: 60px;"></div>
            </div>
            <div class="col-6">
                <p class="fw-bold mb-1">Người lập phiếu</p>
                <p class="text-muted fst-italic small mb-5">(Ký, ghi rõ họ tên)</p>
                <div style="height: 60px;"></div>
                <p class="fw-bold">@Model.TenNguoiNhan</p> </div>
        </div>
        
        <div class="text-center mt-5 pt-4 border-top">
            <p class="fw-bold mb-1" style="font-size: 0.95rem;">Cảm ơn quý khách đã mua sắm tại Fashion Store!</p>
            <p class="text-muted mb-0" style="font-size: 0.85rem;">
                Hỗ trợ đổi trả miễn phí trong vòng 7 ngày nếu có lỗi từ nhà sản xuất. Xin vui lòng giữ lại hóa đơn này.
            </p>
        </div>

    </div>

</body>
</html>