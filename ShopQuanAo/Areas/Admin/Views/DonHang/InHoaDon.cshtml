@model ShopQuanAo.Models.DonHang

@{
    // Tắt Layout chung của Admin để trang in trắng tinh giống tờ A4
    Layout = null; 
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Hóa Đơn - #@Model.MaDH - Fashion Store</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
    
    <style>
        body {
            background-color: #f0f0f0; 
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #333;
        }

        /* KHUNG GIẤY A4 TRÊN MÀN HÌNH */
        .invoice-box {
            max-width: 800px;
            margin: 40px auto;
            padding: 50px;
            background: #fff;
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.15); 
            border-radius: 8px;
        }

        .invoice-header {
            border-bottom: 2px solid #2c3e50;
            padding-bottom: 20px;
            margin-bottom: 30px;
        }

        .table-invoice th {
            background-color: #f8f9fa !important;
            color: #2c3e50;
            text-transform: uppercase;
            font-size: 0.9rem;
            -webkit-print-color-adjust: exact; 
            print-color-adjust: exact;
        }

        .table-invoice td, .table-invoice th {
            vertical-align: middle;
        }

        .info-box {
            background-color: #f8f9fa;
            border-left: 4px solid #e74c3c; 
            padding: 15px;
            border-radius: 0 5px 5px 0;
            -webkit-print-color-adjust: exact;
        }

        /* CSS ĐẶC BIỆT KHI IN (ẨN NÚT, XÓA ĐỔ BÓNG, CĂN LỀ) */
       /* ==================================================== */
        /* CSS ĐẶC BIỆT CHỈ ÁP DỤNG KHI MÁY IN HOẠT ĐỘNG */
        /* ==================================================== */
        @@media print {
            body { background-color: #fff; }
            .invoice-box { 
                max-width: 100%;
                margin: 0; 
                padding: 0; 
                box-shadow: none; 
                border: none;
            }
            .no-print { display: none !important; }
            
            @@page {
                margin: 1.5cm; 
                size: A4 portrait;
            }
        }
        }
    </style>
</head>
<body>

    <div class="text-center mt-4 mb-3 no-print">
        <button onclick="window.print()" class="btn btn-primary btn-lg fw-bold me-3 px-4 shadow-sm">
            <i class="fas fa-print me-2"></i> IN HOẶC LƯU PDF
        </button>
        <button onclick="window.close()" class="btn btn-secondary btn-lg fw-bold px-4 shadow-sm">
            <i class="fas fa-times me-2"></i> ĐÓNG TRANG
        </button>
    </div>

    <div class="invoice-box" id="invoice">
        
        <div class="row invoice-header align-items-center">
            <div class="col-7">
                <h2 class="fw-bolder text-danger mb-2" style="letter-spacing: 1px;">
                    <i class="fas fa-tshirt me-2"></i>FASHION STORE
                </h2>
                <p class="mb-1 text-muted"><i class="fas fa-map-marker-alt me-2" style="width: 15px;"></i> 123 Đường Tôn Đức Thắng, Q. Đống Đa, Hà Nội</p>
                <p class="mb-1 text-muted"><i class="fas fa-phone-alt me-2" style="width: 15px;"></i> Hotline: 0909.123.456</p>
                <p class="mb-0 text-muted"><i class="fas fa-envelope me-2" style="width: 15px;"></i> Email: cskh@fashionstore.com</p>
            </div>
            <div class="col-5 text-end">
                <h1 class="fw-bold text-uppercase" style="color: #2c3e50; letter-spacing: 3px;">HÓA ĐƠN</h1>
                <p class="mb-1 fs-5 fw-bold">Mã HĐ: <span class="text-danger">#@Model.MaDH.ToString("D5")</span></p>
                <p class="mb-0 text-muted">Ngày in: @DateTime.Now.ToString("dd/MM/yyyy HH:mm")</p>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-12">
                <h6 class="fw-bold text-uppercase text-secondary mb-3">THÔNG TIN GIAO HÀNG</h6>
                <div class="info-box">
                    <div class="row">
                        <div class="col-md-6">
                            <p class="mb-2"><strong>Người nhận:</strong> @Model.TenNguoiNhan</p>
                            <p class="mb-0"><strong>Số điện thoại:</strong> @Model.SDTNguoiNhan</p>
                        </div>
                        <div class="col-md-6">
                            <p class="mb-2"><strong>Ngày đặt hàng:</strong> @Model.NgayDat.ToString("dd/MM/yyyy HH:mm")</p>
                            <p class="mb-0"><strong>Thanh toán:</strong> <span class="badge bg-dark">Thanh toán tiêu chuẩn</span></p>
                        </div>
                        <div class="col-12 mt-2 pt-2 border-top">
                            <p class="mb-0"><strong>Địa chỉ giao:</strong> @Model.DiaChiGiao</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <h6 class="fw-bold text-uppercase text-secondary mb-3 mt-5">CHI TIẾT ĐƠN HÀNG</h6>
        <table class="table table-bordered table-invoice mb-4">
            <thead>
                <tr>
                    <th class="text-center" width="5%">STT</th>
                    <th width="40%">Tên Sản Phẩm</th>
                    <th class="text-center" width="15%">Phân loại</th>
                    <th class="text-center" width="10%">SL</th>
                    <th class="text-end" width="15%">Đơn Giá</th>
                    <th class="text-end" width="15%">Thành Tiền</th>
                </tr>
            </thead>
            <tbody>
                @{ int stt = 1; }
                @if (Model.ChiTietDonHangs != null && Model.ChiTietDonHangs.Any())
                {
                    foreach (var ct in Model.ChiTietDonHangs)
                    {
                        <tr>
                            <td class="text-center">@stt</td>
                            <td class="fw-bold">@ct.BienTheSanPham.SanPham.TenSP</td>
                            <td class="text-center">@ct.BienTheSanPham.MauSac - @ct.BienTheSanPham.KichThuoc</td>
                            <td class="text-center">@ct.SoLuong</td>
                            <td class="text-end">@ct.BienTheSanPham.SanPham.GiaBan.ToString("#,##0") đ</td>
                            <td class="text-end fw-bold">@((ct.SoLuong * ct.BienTheSanPham.SanPham.GiaBan).ToString("#,##0")) đ</td>
                        </tr>
                        stt++;
                    }
                }
                else
                {
                    <tr>
                        <td colspan="6" class="text-center text-muted py-3">Không có dữ liệu chi tiết đơn hàng</td>
                    </tr>
                }
            </tbody>
            <tfoot>
                <tr>
                    <td colspan="5" class="text-end">Phí vận chuyển:</td>
                    <td class="text-end text-muted">0 đ</td>
                </tr>
                <tr>
                    <td colspan="5" class="text-end fw-bold fs-5 align-middle">TỔNG TIỀN THANH TOÁN:</td>
                    <td class="text-end fw-bolder text-danger fs-4 align-middle">@Model.TongTien.ToString("#,##0") đ</td>
                </tr>
            </tfoot>
        </table>

        <div class="row mt-5 pt-3">
            <div class="col-6 text-center">
                <p class="fw-bold mb-5 pb-4">Khách hàng</p>
                <p class="text-muted fst-italic">(Ký, ghi rõ họ tên)</p>
            </div>
            <div class="col-6 text-center">
                <p class="fw-bold mb-5 pb-4">Người lập phiếu</p>
                <p class="text-muted fst-italic">(Ký, ghi rõ họ tên)</p>
            </div>
        </div>
        
        <div class="text-center mt-5 pt-4 border-top">
            <p class="text-muted fst-italic mb-1" style="font-size: 0.95rem;">
                Cảm ơn quý khách đã tin tưởng và mua sắm tại Fashion Store!
            </p>
            <p class="text-muted" style="font-size: 0.85rem;">
                * Hỗ trợ đổi trả miễn phí trong vòng 7 ngày nếu có lỗi từ nhà sản xuất.
            </p>
        </div>

    </div>
</body>
</html>