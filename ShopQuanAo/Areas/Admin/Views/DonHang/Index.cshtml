@using X.PagedList
@using X.PagedList.Mvc.Core
@model IPagedList<ShopQuanAo.Models.DonHang>

@{
    ViewData["Title"] = "Quản lý Đơn hàng";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0 text-primary"><i class="fas fa-clipboard-list me-2"></i>Quản Lý Đơn Hàng</h4>
        <div class="text-muted small mt-1">Theo dõi, cập nhật trạng thái và xử lý giao dịch.</div>
    </div>
</div>

<div class="card border-0 shadow-sm mb-3">
    <div class="card-body p-3">
        <form asp-action="Index" method="get" class="row g-2">
            <div class="col-md-10">
                <div class="input-group">
                    <span class="input-group-text bg-light border-0"><i class="fas fa-search text-muted"></i></span>
                    <input type="text" name="searchKeyword" value="@ViewBag.SearchKeyword" 
                           class="form-control bg-light border-0" placeholder="Nhập mã đơn hàng (#123) hoặc tên, SĐT khách hàng...">
                </div>
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary w-100 fw-bold">Tìm đơn</button>
            </div>
        </form>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success border-0 shadow-sm mb-4 rounded-3">
        <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger border-0 shadow-sm mb-4 rounded-3">
        <i class="fas fa-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]
    </div>
}

<div class="main-card card border-0 mb-5 shadow-sm">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted small text-uppercase">
                    <tr>
                        <th class="border-0 ps-4">Mã ĐH</th>
                        <th class="border-0">Ngày Đặt</th>
                        <th class="border-0">Khách Hàng</th>
                        <th class="border-0 text-end">Tổng Tiền</th>
                        <th class="border-0 text-center">Trạng Thái</th>
                        <th class="border-0 text-center pe-4" style="min-width: 150px;">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 fw-bold text-dark">#@item.MaDH</td>
                                <td>
                                    <div class="text-dark">@item.NgayDat.ToString("dd/MM/yyyy")</div>
                                    <div class="text-muted small">@item.NgayDat.ToString("HH:mm")</div>
                                </td>
                                <td>
                                    <div class="fw-bold text-primary">@item.TenNguoiNhan</div>
                                    <div class="text-muted small">@item.SDTNguoiNhan</div>
                                </td>
                                <td class="text-end fw-bold text-danger">
                                    @item.TongTien.ToString("#,##0") đ
                                </td>
                                <td class="text-center">
                                    @if (item.TrangThaiDH == 0 || item.TrangThaiDH == 1) {
                                        <span class="badge rounded-pill bg-warning bg-opacity-10 text-warning border px-3 py-2">Chờ duyệt</span>
                                    } else if (item.TrangThaiDH == 2) {
                                        <span class="badge rounded-pill bg-info bg-opacity-10 text-info border px-3 py-2">Đang giao</span>
                                    } else if (item.TrangThaiDH == 3) {
                                        <span class="badge rounded-pill bg-success bg-opacity-10 text-success border px-3 py-2">Thành công</span>
                                    } else {
                                        <span class="badge rounded-pill bg-secondary bg-opacity-10 text-secondary border px-3 py-2">Đã hủy</span>
                                    }
                                </td>
                                <td class="text-center pe-4">
                                    <div class="btn-group shadow-sm">
                                        <a asp-action="Details" asp-route-id="@item.MaDH" class="btn btn-sm btn-light border" title="Xem chi tiết"><i class="fas fa-eye text-primary"></i></a>
                                        <a asp-action="InHoaDon" asp-route-id="@item.MaDH" target="_blank" class="btn btn-sm btn-light border" title="In"><i class="fas fa-print"></i></a>
                                        
                                        @if (item.TrangThaiDH == 1) {
                                            <form asp-action="XacNhan" asp-route-id="@item.MaDH" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-light border text-info" onclick="return confirm('Duyệt đơn này?')"><i class="fas fa-check"></i></button>
                                            </form>
                                        }
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.PageCount > 1)
    {
        <div class="card-footer bg-white border-top-0 d-flex justify-content-between align-items-center py-3 px-4">
            <div class="text-muted small">
                Hiển thị trang <strong>@Model.PageNumber</strong> / @Model.PageCount (Tổng @Model.TotalItemCount đơn hàng)
            </div>
            <div>
                @Html.PagedListPager(Model, page => Url.Action("Index", new { page, searchKeyword = ViewBag.SearchKeyword }), 
                    new X.PagedList.Mvc.Core.PagedListRenderOptions {
                        LiElementClasses = new string[] { "page-item" },
                        PageClasses = new string[] { "page-link", "rounded-circle", "mx-1", "border-0", "shadow-sm" }
                    })
            </div>
        </div>
    }
</div>

<style>
    .pagination { margin-bottom: 0; }
    .page-item.active .page-link { background-color: #3f6ad8 !important; color: white !important; }
</style>