@model IEnumerable<ShopQuanAo.Models.DonHang>
@{
    ViewData["Title"] = "Quản lý Đơn hàng";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm border-0 mt-3">
        <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm border-0 mt-3">
        <i class="fas fa-times-circle me-2"></i> @TempData["ErrorMessage"] <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow mb-4 border-0 mt-3">
    <div class="card-header py-3 bg-white">
        <h6 class="m-0 font-weight-bold text-primary">Danh sách Đơn đặt hàng</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th>Mã ĐH</th>
                        <th>Ngày Đặt</th>
                        <th>Người Nhận</th>
                        <th>Tổng Tiền</th>
                        <th class="text-center">Trạng Thái</th>
                        <th class="text-center" style="min-width: 150px;">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">#@item.MaDH</td>
                            <td>@item.NgayDat.ToString("dd/MM/yyyy HH:mm")</td>
                            <td>
                                <strong>@item.TenNguoiNhan</strong><br />
                                <small class="text-muted"><i class="fas fa-phone"></i> @item.SDTNguoiNhan</small>
                            </td>
                            <td class="text-danger fw-bold">@item.TongTien.ToString("#,##0") đ</td>
                            
                            <td class="text-center">
                                @if (item.TrangThaiDH == 1)
                                {
                                    <span class="badge bg-warning text-dark"><i class="fas fa-spinner fa-spin"></i> Chờ xác nhận</span>
                                }
                                else if (item.TrangThaiDH == 2)
                                {

                                    <span class="badge bg-info text-dark"><i class="fas fa-truck"></i> Đang giao</span>
                                }
                                else if (item.TrangThaiDH == 3)
                                {

                                    <span class="badge bg-success"><i class="fas fa-check-circle"></i> Hoàn thành</span>
                                }
                                else
                                {

                                    <span class="badge bg-secondary"><i class="fas fa-times-circle"></i> Đã hủy</span>
                                }
                            </td>
                            
                            <td class="text-center">
                                <div class="d-flex justify-content-center gap-1">
                                    <a asp-action="Details" asp-route-id="@item.MaDH" class="btn btn-sm btn-primary" title="Xem chi tiết"><i class="fas fa-eye"></i></a>

                                    @if (item.TrangThaiDH == 1)
                                    {
                                        <form asp-action="XacNhan" asp-route-id="@item.MaDH" method="post" style="display:inline;" onsubmit="return confirm('Xác nhận giao đơn hàng #@item.MaDH?');">
                                            <button type="submit" class="btn btn-sm btn-info text-white" title="Xác nhận giao"><i class="fas fa-check"></i></button>
                                        </form>
                                        <form asp-action="HuyDon" asp-route-id="@item.MaDH" method="post" style="display:inline;" onsubmit="return confirm('Bạn chắc chắn muốn hủy đơn hàng #@item.MaDH?');">
                                            <button type="submit" class="btn btn-sm btn-danger" title="Hủy đơn"><i class="fas fa-times"></i></button>
                                        </form>
                                    }
                                    else if (item.TrangThaiDH == 2)
                                    {
                                        <form asp-action="HoanThanh" asp-route-id="@item.MaDH" method="post" style="display:inline;" onsubmit="return confirm('Xác nhận đơn #@item.MaDH đã giao thành công?');">
                                            <button type="submit" class="btn btn-sm btn-success" title="Đã giao thành công"><i class="fas fa-check-double"></i></button>
                                        </form>
                                        <form asp-action="HuyDon" asp-route-id="@item.MaDH" method="post" style="display:inline;" onsubmit="return confirm('Khách bom hàng? Xác nhận hủy đơn #@item.MaDH?');">
                                            <button type="submit" class="btn btn-sm btn-danger" title="Hủy đơn (Khách bom)"><i class="fas fa-times"></i></button>
                                        </form>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>