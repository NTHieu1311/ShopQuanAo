@model ShopQuanAo.Models.BienTheSanPham
@{
    ViewData["Title"] = "Chỉnh Sửa Biến Thể";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0 text-primary"><i class="fas fa-edit me-2"></i>Cập Nhật Biến Thể</h4>
        <div class="text-muted small mt-1">Chỉnh sửa thông tin và cập nhật số lượng tồn kho.</div>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm fw-medium">
        <i class="fas fa-arrow-left me-2"></i>Quay lại kho
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <form asp-action="Edit">
            <input type="hidden" asp-for="MaBienThe" />
            
            <div class="main-card card border-0 mb-4">
                <div class="card-body p-4 p-md-5">
                    
                    <div class="mb-4">
                        <label asp-for="MaSP" class="form-label fw-bold text-muted small text-uppercase">Sản phẩm gốc</label>
                        <select asp-for="MaSP" class="form-select form-select-lg bg-light border-0" asp-items="ViewBag.MaSP"></select>
                    </div>
                    
                    <div class="row">
                        <div class="col-sm-6 mb-4">
                            <label asp-for="MauSac" class="form-label fw-bold text-muted small text-uppercase">Màu sắc <span class="text-danger">*</span></label>
                            <input asp-for="MauSac" class="form-control form-control-lg bg-light border-0" required />
                        </div>
                        <div class="col-sm-6 mb-4">
                            <label asp-for="KichThuoc" class="form-label fw-bold text-muted small text-uppercase">Kích thước <span class="text-danger">*</span></label>
                            <input asp-for="KichThuoc" class="form-control form-control-lg bg-light border-0" required />
                        </div>
                    </div>
                    
                    <div class="mb-5 border-top pt-4">
                        <label asp-for="SoLuongTon" class="form-label fw-bold text-muted small text-uppercase">Tồn kho hiện tại <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <input asp-for="SoLuongTon" type="number" class="form-control form-control-lg bg-warning bg-opacity-10 text-dark fw-bold border-0" min="0" required />
                            <span class="input-group-text bg-warning bg-opacity-10 border-0 fw-bold">SP</span>
                        </div>
                        <div class="text-muted small mt-2"><i class="fas fa-info-circle me-1"></i> Cập nhật trực tiếp số lượng nếu có chênh lệch thực tế.</div>
                    </div>

                    <div class="d-flex justify-content-end align-items-center">
                        <button type="submit" class="btn btn-warning text-dark px-5 py-2 fw-bold shadow-sm w-100" style="border-radius: 8px;">
                            <i class="fas fa-save me-2"></i> Lưu Cập Nhật
                        </button>
                    </div>

                </div>
            </div>
        </form>
    </div>
</div>