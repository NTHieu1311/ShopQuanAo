@model ShopQuanAo.Models.BienTheSanPham
@{
    ViewData["Title"] = "Thêm Biến Thể";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0 text-primary"><i class="fas fa-plus-circle me-2"></i>Thêm Biến Thể Mới</h4>
        <div class="text-muted small mt-1">Thiết lập màu sắc, kích thước và nhập kho.</div>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm fw-medium">
        <i class="fas fa-arrow-left me-2"></i>Quay lại kho
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <form asp-action="Create">
            <div class="main-card card border-0 mb-4">
                <div class="card-body p-4 p-md-5">
                    
                    <div class="mb-4">
                        <label asp-for="MaSP" class="form-label fw-bold text-muted small text-uppercase">Chọn Sản phẩm <span class="text-danger">*</span></label>
                        <select asp-for="MaSP" class="form-select form-select-lg bg-light border-0" asp-items="ViewBag.MaSP"></select>
                    </div>
                    
                    <div class="row">
                        <div class="col-sm-6 mb-4">
                            <label asp-for="MauSac" class="form-label fw-bold text-muted small text-uppercase">Màu sắc <span class="text-danger">*</span></label>
                            <input asp-for="MauSac" class="form-control form-control-lg bg-light border-0" placeholder="VD: Đen, Trắng..." required autocomplete="off" />
                        </div>
                        <div class="col-sm-6 mb-4">
                            <label asp-for="KichThuoc" class="form-label fw-bold text-muted small text-uppercase">Kích thước <span class="text-danger">*</span></label>
                            <input asp-for="KichThuoc" class="form-control form-control-lg bg-light border-0" placeholder="VD: S, M, L, XL..." required autocomplete="off" />
                        </div>
                    </div>
                    
                    <div class="mb-5 border-top pt-4">
                        <label asp-for="SoLuongTon" class="form-label fw-bold text-muted small text-uppercase">Số lượng nhập kho ban đầu <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <input asp-for="SoLuongTon" type="number" class="form-control form-control-lg bg-light border-0" value="0" min="0" required />
                            <span class="input-group-text bg-light border-0 text-muted">Sản phẩm</span>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end align-items-center">
                        <button type="submit" class="btn btn-primary px-5 py-2 fw-bold shadow-sm w-100" style="border-radius: 8px;">
                            <i class="fas fa-save me-2"></i> Lưu Biến Thể
                        </button>
                    </div>

                </div>
            </div>
        </form>
    </div>
</div>