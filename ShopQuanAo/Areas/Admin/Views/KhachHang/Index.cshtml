@model IEnumerable<ShopQuanAo.Models.KhachHang>
@{
    ViewData["Title"] = "Quản lý Khách Hàng";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow border-0 mb-4">
    <div class="card-header bg-white py-3">
        <h6 class="m-0 font-weight-bold text-primary">Danh sách Khách Hàng</h6>
    </div>
    <div class="card-body">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th>Họ Tên</th>
                    <th>Thông tin liên hệ</th>
                    <th class="text-center">Tài khoản (Đăng nhập)</th>
                    <th class="text-center">Điểm Tích Lũy</th>
                    <th class="text-center">Trạng Thái</th>
                    <th class="text-center">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold text-dark">@item.HoTen</td>
                        <td>
                            <i class="fas fa-phone text-muted"></i> @item.SoDienThoai <br />
                            <i class="fas fa-envelope text-muted"></i> @item.TaiKhoan.Email
                        </td>
                        <td class="text-center fw-bold text-primary">@item.TaiKhoan.TenDangNhap</td>
                        <td class="text-center text-warning fw-bold">@item.DiemTichLuy</td>
                        <td class="text-center">
                            @if (item.TaiKhoan.TrangThai == 1)
                            {
                                <span class="badge bg-success"><i class="fas fa-unlock"></i> Đang hoạt động</span>
                            }
                            else
                            {
                                <span class="badge bg-danger"><i class="fas fa-lock"></i> Đã bị khóa</span>
                            }
                        </td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.MaTK" class="btn btn-sm btn-info text-white" title="Xem & Chỉnh sửa">
                                <i class="fas fa-user-edit"></i> Quản lý
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!Model.Any())
        {
            <div class="text-center text-muted mt-3">Chưa có khách hàng nào đăng ký.</div>
        }
    </div>
</div>