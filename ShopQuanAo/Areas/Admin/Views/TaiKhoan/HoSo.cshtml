@model ShopQuanAo.Models.TaiKhoan
@{
    ViewData["Title"] = "Thông Tin Tài Khoản";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0 text-primary"><i class="fas fa-user-shield me-2"></i>Hồ Sơ Quản Trị Viên</h4>
        <div class="text-muted small mt-1">Quản lý thông tin cá nhân và bảo mật đăng nhập của bạn.</div>
    </div>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" style="border-radius: 10px;" role="alert">
        <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show border-0 shadow-sm mb-4" style="border-radius: 10px;" role="alert">
        <i class="fas fa-exclamation-triangle me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="row">
    <div class="col-xl-4 col-lg-5 mb-4">
        <div class="main-card card border-0 h-100 position-relative overflow-hidden">
            <div class="bg-primary bg-opacity-10 position-absolute top-0 start-0 w-100" style="height: 120px; z-index: 1;"></div>
            
            <div class="card-body text-center p-4 d-flex flex-column justify-content-center align-items-center position-relative" style="z-index: 2; margin-top: 40px;">
                <img class="img-profile rounded-circle mb-3 shadow" src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(Model.TenDangNhap)&background=3f6ad8&color=fff&size=150" alt="Admin Avatar" style="border: 5px solid #fff; background-color: #fff;">
                
                <h4 class="fw-bold text-dark mb-1">@Model.TenDangNhap</h4>
                <div class="badge bg-danger px-3 py-2 rounded-pill mt-2 shadow-sm fw-medium">
                    <i class="fas fa-shield-alt me-1"></i> Quản Trị Viên Hệ Thống
                </div>
                
                <div class="bg-light p-3 rounded-3 mt-4 w-100 text-start">
                    <div class="d-flex align-items-center text-muted small mb-2">
                        <i class="fas fa-calendar-alt me-2" style="width: 15px;"></i> Ngày tham gia: @Model.NgayTao.ToString("dd/MM/yyyy")
                    </div>
                    <div class="d-flex align-items-center text-muted small">
                        <i class="fas fa-info-circle text-primary me-2" style="width: 15px;"></i> Tài khoản có đặc quyền cao nhất.
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-xl-8 col-lg-7">
        
        <div class="main-card card border-0 mb-4">
            <div class="card-header bg-white py-3 border-bottom-0 pt-4 px-4">
                <h6 class="m-0 fw-bold text-primary"><i class="fas fa-id-card-alt me-2"></i>Thông tin liên hệ</h6>
            </div>
            <div class="card-body px-4 pb-4">
                <form asp-area="Admin" asp-controller="TaiKhoan" asp-action="CapNhatHoSo" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="MaTK" value="@Model.MaTK" />
                    
                    <div class="row">
                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-bold text-muted small text-uppercase">Tên đăng nhập</label>
                            <input type="text" class="form-control form-control-lg bg-light text-muted border-0 fw-bold" value="@Model.TenDangNhap" readonly>
                        </div>
                        <div class="col-md-6 mb-4">
                            <label class="form-label fw-bold text-muted small text-uppercase">Email nhận thông báo <span class="text-danger">*</span></label>
                            <div class="input-group">
                                <span class="input-group-text bg-light border-0"><i class="fas fa-envelope text-muted"></i></span>
                                <input type="email" name="Email" class="form-control form-control-lg bg-light border-0" value="@Model.Email" required autocomplete="off">
                            </div>
                        </div>
                    </div>
                    <div class="text-end border-top pt-3">
                        <button type="submit" class="btn btn-primary fw-bold px-4 py-2 shadow-sm" style="border-radius: 8px;">
                            <i class="fas fa-save me-2"></i> Lưu Cập Nhật
                        </button>
                    </div>
                </form>
            </div>
        </div>

        <div class="main-card card border-0 border-top border-danger border-4 shadow-sm">
            <div class="card-header bg-white py-3 border-bottom-0 pt-4 px-4">
                <h6 class="m-0 fw-bold text-danger"><i class="fas fa-key me-2"></i>Đổi Mật Khẩu Bảo Mật</h6>
            </div>
            <div class="card-body px-4 pb-4">
                <form asp-area="Admin" asp-controller="TaiKhoan" asp-action="DoiMatKhau" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="MaTK" value="@Model.MaTK" />
                    
                    <div class="mb-4">
                        <label class="form-label fw-bold text-muted small text-uppercase">Mật khẩu hiện tại <span class="text-danger">*</span></label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0"><i class="fas fa-unlock-alt text-muted"></i></span>
                            <input type="password" name="MatKhauHienTai" class="form-control form-control-lg bg-light border-0" required placeholder="Nhập để xác minh danh tính...">
                        </div>
                    </div>
                    
                    <div class="row mb-4">
                        <div class="col-md-6 mb-4 mb-md-0">
                            <label class="form-label fw-bold text-muted small text-uppercase">Mật khẩu mới <span class="text-danger">*</span></label>
                            <input type="password" name="MatKhauMoi" class="form-control form-control-lg bg-light border-0" required minlength="6" placeholder="Ít nhất 6 ký tự">
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-bold text-muted small text-uppercase">Xác nhận mật khẩu mới <span class="text-danger">*</span></label>
                            <input type="password" name="XacNhanMatKhau" class="form-control form-control-lg bg-light border-0" required minlength="6" placeholder="Nhập lại mật khẩu mới">
                        </div>
                    </div>
                    
                    <div class="text-end border-top pt-3">
                        <button type="submit" class="btn btn-danger fw-bold px-4 py-2 shadow-sm" style="border-radius: 8px;">
                            <i class="fas fa-shield-alt me-2"></i> Cập Nhật Mật Khẩu
                        </button>
                    </div>
                </form>
            </div>
        </div>
        
    </div>
</div>