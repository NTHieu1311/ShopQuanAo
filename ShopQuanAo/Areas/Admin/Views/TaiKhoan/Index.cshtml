@model IEnumerable<ShopQuanAo.Models.TaiKhoan>
@{
    ViewData["Title"] = "Quản lý Tài Khoản";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0 text-primary"><i class="fas fa-users-cog me-2"></i>Toàn Bộ Tài Khoản</h4>
        <div class="text-muted small mt-1">Quản lý tài khoản Khách hàng và Quản trị viên hệ thống.</div>
    </div>
    <a asp-action="Create" class="btn btn-primary rounded-pill px-4 py-2 shadow-sm fw-medium">
        <i class="fas fa-plus me-2"></i>Tạo tài khoản mới
    </a>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show border-0 shadow-sm mb-4" style="border-radius: 10px;" role="alert">
        <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="main-card card border-0 mb-5">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light text-muted small text-uppercase">
                    <tr>
                        <th class="border-0 ps-4">Tài khoản đăng nhập</th>
                        <th class="border-0">Email liên hệ</th>
                        <th class="border-0 text-center">Ngày tạo</th>
                        <th class="border-0 text-center">Trạng Thái</th>
                        <th class="border-0 text-end pe-4">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center">
                                        <img src="https://ui-avatars.com/api/?name=@Uri.EscapeDataString(item.TenDangNhap)&background=random&color=fff&rounded=true"
                                             class="rounded-circle shadow-sm me-3" style="width: 40px; height: 40px;" alt="Avatar" />
                                        <div>
                                            <div class="fw-bold text-dark fs-6">@item.TenDangNhap</div>
                                            <div class="text-muted small">ID: #@item.MaTK</div>
                                        </div>
                                    </div>
                                </td>
                                
                                <td><i class="fas fa-envelope text-muted me-2 small"></i>@item.Email</td>
                                
                                <td class="text-center text-muted">@item.NgayTao.ToString("dd/MM/yyyy")</td>
                                
                                <td class="text-center">
                                    @if (item.TrangThai == 1)
                                    {
                                        <span class="badge rounded-pill bg-success bg-opacity-10 text-success border border-success border-opacity-25 px-3 py-2">
                                            <i class="fas fa-unlock me-1"></i> Hoạt động
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge rounded-pill bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 px-3 py-2">
                                            <i class="fas fa-lock me-1"></i> Bị khóa
                                        </span>
                                    }
                                </td>
                                
                                <td class="text-end pe-4">
                                    <div class="btn-group shadow-sm" role="group">
                                        <a asp-action="Edit" asp-route-id="@item.MaTK" class="btn btn-sm btn-light text-primary border" data-bs-toggle="tooltip" title="Thiết lập/Khóa">
                                            <i class="fas fa-user-cog"></i>
                                        </a>
                                        <a asp-action="Delete" asp-route-id="@item.MaTK" class="btn btn-sm btn-light text-danger border" data-bs-toggle="tooltip" title="Xóa tài khoản">
                                            <i class="fas fa-user-times"></i>
                                        </a>
                                    </div>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="5" class="text-center py-5">
                                <div class="d-inline-flex align-items-center justify-content-center bg-light rounded-circle mb-3" style="width: 80px; height: 80px;">
                                    <i class="fas fa-user-slash fa-2x text-muted opacity-50"></i>
                                </div>
                                <h6 class="fw-bold text-dark">Chưa có dữ liệu</h6>
                                <p class="text-muted small mb-0">Không tìm thấy tài khoản nào trong hệ thống.</p>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
        var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
            return new bootstrap.Tooltip(tooltipTriggerEl)
        })
    </script>
}