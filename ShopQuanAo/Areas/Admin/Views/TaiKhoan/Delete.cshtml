@model ShopQuanAo.Models.TaiKhoan
@{
    ViewData["Title"] = "Xóa Tài Khoản";
}

<div class="card shadow border-0 col-md-6 mx-auto mt-5 border-danger border-top border-4 text-center p-4">
    <i class="fas fa-user-times fa-3x text-danger mb-3"></i>
    <h4 class="fw-bold">Xác nhận xóa tài khoản?</h4>
    
    <div class="bg-light p-3 rounded mt-3 text-start">
        <p><strong>Username:</strong> @Model.TenDangNhap</p>
        <p><strong>Email:</strong> @Model.Email</p>
        <p class="mb-0"><strong>Ngày tạo:</strong> @Model.NgayTao.ToString("dd/MM/yyyy")</p>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger mt-4 text-start">
            <i class="fas fa-exclamation-circle"></i> @TempData["ErrorMessage"]
        </div>
    }
    else
    {
        <div class="alert alert-warning mt-4 text-start">
            <strong>Lưu ý:</strong> Hành động này sẽ xóa vĩnh viễn tài khoản khỏi cơ sở dữ liệu.
        </div>
    }

    <form asp-action="Delete" class="mt-4">
        <input type="hidden" asp-for="MaTK" />
        <a asp-action="Index" class="btn btn-secondary px-4 me-2">Hủy</a>
        <button type="submit" class="btn btn-danger px-4">Xác nhận Xóa</button>
    </form>
</div>