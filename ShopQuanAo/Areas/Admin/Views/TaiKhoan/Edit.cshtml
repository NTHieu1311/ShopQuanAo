@model ShopQuanAo.Models.TaiKhoan
@{
    ViewData["Title"] = "Sửa Tài Khoản";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0 text-primary"><i class="fas fa-user-cog me-2"></i>Cập Nhật Tài Khoản</h4>
        <div class="text-muted small mt-1">Chỉnh sửa bảo mật cho tài khoản: <strong class="text-dark">@Model.TenDangNhap</strong></div>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm fw-medium">
        <i class="fas fa-arrow-left me-2"></i>Quay lại
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <form asp-action="Edit">
            <input type="hidden" asp-for="MaTK" />
            <input type="hidden" asp-for="NgayTao" />
            
            <div class="main-card card border-0 mb-4">
                <div class="card-body p-4 p-md-5">
                    
                    <div class="mb-4">
                        <label asp-for="TenDangNhap" class="form-label fw-bold text-muted small text-uppercase">Tên đăng nhập</label>
                        <div class="input-group">
                            <span class="input-group-text bg-light border-0 text-muted"><i class="fas fa-lock"></i></span>
                            <input asp-for="TenDangNhap" class="form-control form-control-lg bg-light border-0 text-muted fw-bold" readonly />
                        </div>
                        <small class="text-muted mt-2 d-block"><i class="fas fa-info-circle me-1"></i> Tên đăng nhập là khóa định danh không thể thay đổi.</small>
                    </div>
                    
                    <div class="mb-4">
                        <label asp-for="Email" class="form-label fw-bold text-muted small text-uppercase">Địa chỉ Email <span class="text-danger">*</span></label>
                        <input asp-for="Email" type="email" class="form-control form-control-lg bg-light border-0" required />
                    </div>
                    
                    <div class="mb-5 border-top pt-4">
                        <label asp-for="MatKhau" class="form-label fw-bold text-muted small text-uppercase">Mật khẩu <span class="text-danger">*</span></label>
                        <input asp-for="MatKhau" type="text" class="form-control form-control-lg bg-light border-0" required />
                    </div>
                    
                    <div class="mb-5 bg-white p-3 rounded-3 shadow-sm border">
                        <label asp-for="TrangThai" class="form-label fw-bold text-muted small text-uppercase mb-2">Trạng thái đăng nhập</label>
                        <select asp-for="TrangThai" class="form-select form-select-lg fw-bold @(Model.TrangThai == 1 ? "bg-success bg-opacity-10 text-success border-success border-opacity-25" : "bg-danger bg-opacity-10 text-danger border-danger border-opacity-25")">
                            @if (Model.TrangThai == 1)
                            {
                                <option value="1" class="text-dark" selected>✅ Đang Hoạt Động (Bình thường)</option>
                                <option value="0" class="text-dark">❌ Khóa (Cấm đăng nhập)</option>
                            }
                            else
                            {
                                <option value="1" class="text-dark">✅ Mở khóa hoạt động</option>
                                <option value="0" class="text-dark" selected>❌ Đang Khóa (Cấm đăng nhập)</option>
                            }
                        </select>
                    </div>
                    
                    <div class="d-flex justify-content-end align-items-center">
                        <button type="submit" class="btn btn-warning text-dark px-5 py-2 fw-bold shadow-sm w-100" style="border-radius: 8px;">
                            <i class="fas fa-save me-2"></i> Lưu Cập Nhật
                        </button>
                    </div>

                </div>
            </div>
        </form>
    </div>
</div>