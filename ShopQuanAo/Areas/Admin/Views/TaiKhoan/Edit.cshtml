@model ShopQuanAo.Models.TaiKhoan
@{
    ViewData["Title"] = "Sửa Tài Khoản";
}

<div class="card shadow border-0 col-md-6 mx-auto mt-4">
    <div class="card-header bg-white py-3"><h6 class="m-0 font-weight-bold text-warning">Cập Nhật Tài Khoản</h6></div>
    <div class="card-body">
        <form asp-action="Edit">
            <input type="hidden" asp-for="MaTK" />
            <input type="hidden" asp-for="NgayTao" /> <div class="mb-3">
            <label asp-for="TenDangNhap" class="form-label fw-bold">Tên đăng nhập</label>
            <input asp-for="TenDangNhap" class="form-control" readonly />
            <small class="text-muted">Tên đăng nhập không thể thay đổi sau khi tạo.</small>
        </div>
        <div class="mb-3">
            <label asp-for="Email" class="form-label fw-bold">Địa chỉ Email</label>
            <input asp-for="Email" type="email" class="form-control" required />
        </div>
        <div class="mb-3">
            <label asp-for="MatKhau" class="form-label fw-bold">Mật khẩu</label>
            <input asp-for="MatKhau" type="text" class="form-control" required />
        </div>
        <div class="mb-4">
            <label asp-for="TrangThai" class="form-label fw-bold">Trạng thái</label>
            <select asp-for="TrangThai" class="form-select border-2 @(Model.TrangThai == 1 ? "border-success" : "border-danger")">
                <option value="1">Đang Hoạt Động</option>
                <option value="0">Khóa (Cấm đăng nhập)</option>
            </select>
        </div>
        <div class="d-flex justify-content-between">
            <a asp-action="Index" class="btn btn-secondary">Quay lại</a>
            <button type="submit" class="btn btn-warning fw-bold text-dark"><i class="fas fa-save"></i> Cập Nhật</button>
        </div>
    </form>
</div>
</div>