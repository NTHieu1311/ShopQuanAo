@model ShopQuanAo.Models.TaiKhoan
@{
    ViewData["Title"] = "Tạo Tài Khoản";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0 text-primary"><i class="fas fa-user-plus me-2"></i>Cấp Tài Khoản Mới</h4>
        <div class="text-muted small mt-1">Khởi tạo nhanh tài khoản Khách hàng hoặc Quản trị viên.</div>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm fw-medium">
        <i class="fas fa-arrow-left me-2"></i>Quay lại danh sách
    </a>
</div>

<form asp-action="Create" method="post">
    <div asp-validation-summary="All" class="alert alert-danger d-none"></div>

    <div class="row">
        <div class="col-lg-6 mb-4">
            <div class="main-card card border-0 h-100">
                <div class="card-body p-4 p-md-5">
                    <h6 class="fw-bold mb-4 border-bottom pb-2 text-primary"><i class="fas fa-shield-alt me-2"></i>Thông tin Hệ thống</h6>
                    
                    <div class="mb-4">
                        <label asp-for="TenDangNhap" class="form-label fw-bold text-muted small text-uppercase">Tên đăng nhập <span class="text-danger">*</span></label>
                        <input asp-for="TenDangNhap" class="form-control form-control-lg bg-light border-0" placeholder="Viết liền không dấu" required autocomplete="off" />
                    </div>

                    <div class="mb-4">
                        <label asp-for="Email" class="form-label fw-bold text-muted small text-uppercase">Email <span class="text-danger">*</span></label>
                        <input asp-for="Email" type="email" class="form-control form-control-lg bg-light border-0" placeholder="nguyenvana@gmail.com" required autocomplete="off" />
                    </div>

                    <div class="mb-4">
                        <label asp-for="MatKhau" class="form-label fw-bold text-muted small text-uppercase">Mật khẩu <span class="text-danger">*</span></label>
                        <input asp-for="MatKhau" type="password" class="form-control form-control-lg bg-light border-0" placeholder="Nhập mật khẩu cấp phát" required />
                    </div>

                    <div class="row">
                        <div class="col-sm-6 mb-4 mb-sm-0">
                            <label asp-for="QuyenTruyCap" class="form-label fw-bold text-muted small text-uppercase">Phân quyền <span class="text-danger">*</span></label>
                            <select asp-for="QuyenTruyCap" class="form-select form-select-lg bg-primary bg-opacity-10 text-primary border-0 fw-bold" id="loaiTaiKhoan">
                                <option value="1">Khách Hàng</option>
                                <option value="2">Quản Trị Viên</option>
                            </select>
                        </div>
                        <div class="col-sm-6">
                            <label asp-for="TrangThai" class="form-label fw-bold text-muted small text-uppercase">Trạng thái <span class="text-danger">*</span></label>
                            <select asp-for="TrangThai" class="form-select form-select-lg bg-light border-0">
                                <option value="1">🟢 Hoạt động</option>
                                <option value="0">🔴 Khóa</option>
                            </select>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-6 mb-4">
            <div class="main-card card border-0 h-100">
                <div class="card-body p-4 p-md-5">
                    <h6 class="fw-bold mb-4 border-bottom pb-2 text-dark"><i class="fas fa-id-card me-2"></i>Hồ sơ Đính kèm (Tùy chọn)</h6>
                    
                    <div class="mb-4">
                        <label class="form-label fw-bold text-muted small text-uppercase">Họ và tên</label>
                        <input type="text" name="HoTen" class="form-control form-control-lg bg-light border-0" placeholder="Nhập họ tên thực tế..." />
                    </div>

                    <div class="mb-4">
                        <label class="form-label fw-bold text-muted small text-uppercase">Số điện thoại</label>
                        <input type="tel" name="SoDienThoai" class="form-control form-control-lg bg-light border-0" placeholder="09xx..." />
                    </div>

                    <div class="mb-4" id="khungDiaChi">
                        <label class="form-label fw-bold text-muted small text-uppercase">Địa chỉ giao hàng</label>
                        <textarea name="DiaChi" class="form-control bg-light border-0" rows="3" placeholder="Nhập địa chỉ nhà..."></textarea>
                    </div>

                    <div class="mb-4" id="khungChucVu" style="display: none;">
                        <label class="form-label fw-bold text-muted small text-uppercase">Chức vụ (Dành cho Admin)</label>
                        <input type="text" name="ChucVu" class="form-control form-control-lg bg-light border-0" placeholder="Ví dụ: Quản lý, Kế toán..." />
                        <div class="text-muted small mt-2"><i class="fas fa-info-circle me-1"></i> Tùy chọn hiển thị chức danh nội bộ.</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card main-card border-0 mb-5">
        <div class="card-body p-4 d-flex justify-content-end align-items-center">
            <a asp-action="Index" class="btn btn-light fw-bold px-4 me-3">Hủy bỏ</a>
            <button type="submit" class="btn btn-primary px-5 py-2 fw-bold shadow-sm" style="border-radius: 8px;">
                <i class="fas fa-check-circle me-2"></i> Xác Nhận Tạo Mới
            </button>
        </div>
    </div>
</form>

@section Scripts {
    <script>
        // Phép thuật JavaScript của bạn được giữ nguyên
        document.getElementById('loaiTaiKhoan').addEventListener('change', function () {
            if (this.value == '1') {
                document.getElementById('khungDiaChi').style.display = 'block';
                document.getElementById('khungChucVu').style.display = 'none';
            } else {
                document.getElementById('khungDiaChi').style.display = 'none';
                document.getElementById('khungChucVu').style.display = 'block';
            }
        });
    </script>
}