@model ShopQuanAo.Models.SanPham

@{
    ViewData["Title"] = "Thêm Sản Phẩm Mới";
}

<div class="card shadow border-0 col-md-10 mx-auto mt-4">
    <div class="card-header bg-white py-3">
        <h6 class="m-0 font-weight-bold text-primary">Thêm Sản Phẩm Mới</h6>
    </div>
    <div class="card-body">
        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <div class="row">
                <div class="col-md-8">
                    <div class="mb-3">
                        <label asp-for="TenSP" class="form-label fw-bold">Tên sản phẩm</label>
                        <input asp-for="TenSP" class="form-control" required />
                    </div>

                    <div class="mb-3">
                        <label asp-for="MaDM" class="form-label fw-bold">Thuộc Danh mục</label>
                        <select asp-for="MaDM" class="form-select" asp-items="ViewBag.MaDM"></select>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="GiaGoc" class="form-label fw-bold">Giá Gốc (VNĐ)</label>
                            <input asp-for="GiaGoc" type="number" class="form-control" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="GiaBan" class="form-label fw-bold">Giá Bán (VNĐ)</label>
                            <input asp-for="GiaBan" type="number" class="form-control" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MoTaChiTiet" class="form-label fw-bold">Mô tả chi tiết</label>
                        <textarea asp-for="MoTaChiTiet" class="form-control" rows="4"></textarea>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="mb-3 border p-3 rounded bg-light text-center">
                        <label class="form-label fw-bold w-100">Hình Ảnh Chính</label>
                        <input type="file" name="HinhAnh" class="form-control mb-2" accept="image/*" id="imgInput" />
                        
                        <img id="imgPreview" src="#" alt="Xem trước ảnh" class="img-fluid d-none rounded border" style="max-height: 200px;" />
                    </div>

                    <div class="mb-4">
                        <label asp-for="TrangThai" class="form-label fw-bold">Trạng thái</label>
                        <select asp-for="TrangThai" class="form-select">
                            <option value="1">Đang bán</option>
                            <option value="0">Ngừng bán</option>
                        </select>
                    </div>
                </div>
            </div>

            <hr />
            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary"><i class="fas fa-arrow-left"></i> Quay lại</a>
                <button type="submit" class="btn btn-primary"><i class="fas fa-save"></i> Lưu Sản Phẩm</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    
    <script>
        imgInput.onchange = evt => {
            const [file] = imgInput.files
            if (file) {
                imgPreview.src = URL.createObjectURL(file)
                imgPreview.classList.remove("d-none");
            }
        }
    </script>
}