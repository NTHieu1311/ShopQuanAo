@model ShopQuanAo.Models.SanPham

@{
    ViewData["Title"] = "Thêm Sản Phẩm Mới";
}

<div class="card shadow border-0 col-md-10 mx-auto mt-4">
    <div class="card-header bg-white py-3">
        <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-plus-circle me-1"></i> Thêm Sản Phẩm Mới</h6>
    </div>
    <div class="card-body p-4">
        <form asp-action="Create" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>
            
            <div class="row">
                <div class="col-md-8">
                    <div class="mb-3">
                        <label asp-for="TenSP" class="form-label fw-bold">Tên sản phẩm <span class="text-danger">*</span></label>
                        <input asp-for="TenSP" class="form-control" placeholder="Nhập tên sản phẩm..." required />
                        <span asp-validation-for="TenSP" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MaDM" class="form-label fw-bold">Thuộc Danh mục <span class="text-danger">*</span></label>
                        <select asp-for="MaDM" class="form-select" asp-items="@ViewBag.ListDanhMuc" required>
                            <option value="">-- Vui lòng chọn danh mục --</option>
                        </select>
                        <span asp-validation-for="MaDM" class="text-danger small"></span>
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label asp-for="GiaGoc" class="form-label fw-bold">Giá Gốc (VNĐ) <span class="text-danger">*</span></label>
                            <input asp-for="GiaGoc" type="number" class="form-control" min="0" required />
                            <span asp-validation-for="GiaGoc" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label asp-for="GiaBan" class="form-label fw-bold">Giá Bán (VNĐ) <span class="text-danger">*</span></label>
                            <input asp-for="GiaBan" type="number" class="form-control" min="0" required />
                            <span asp-validation-for="GiaBan" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label asp-for="MoTaChiTiet" class="form-label fw-bold">Mô tả chi tiết</label>
                        <textarea asp-for="MoTaChiTiet" class="form-control" rows="5" placeholder="Nhập mô tả sản phẩm..."></textarea>
                        <span asp-validation-for="MoTaChiTiet" class="text-danger small"></span>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="mb-4 border p-3 rounded bg-light text-center">
                        <label class="form-label fw-bold w-100 border-bottom pb-2">Hình Ảnh Chính</label>
                        <input type="file" name="HinhAnh" class="form-control mb-3" accept="image/*" id="imgInput" />
                        
                        <img id="imgPreview" src="#" alt="Xem trước ảnh" class="img-fluid d-none rounded shadow-sm border bg-white" style="max-height: 250px; object-fit: contain; width: 100%;" />
                    </div>

                    <div class="mb-4 border p-3 rounded bg-light">
                        <label asp-for="TrangThai" class="form-label fw-bold border-bottom pb-2 w-100">Trạng thái hiển thị</label>
                        <select asp-for="TrangThai" class="form-select">
                            <option value="1" selected>Đang bán</option>
                            <option value="0">Ngừng bán</option>
                        </select>
                    </div>
                </div>
            </div>

            <hr class="mt-4" />
            <div class="d-flex justify-content-between align-items-center">
                <a asp-action="Index" class="btn btn-outline-secondary px-4">
                    <i class="fas fa-arrow-left me-1"></i> Quay lại
                </a>
                <button type="submit" class="btn btn-primary px-5 py-2 fw-bold shadow-sm">
                    <i class="fas fa-save me-1"></i> Lưu Sản Phẩm
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        // Gọi script hỗ trợ báo lỗi từ ASP.NET Core
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    
    <script>
        // JS Xử lý hiển thị ảnh xem trước mượt mà hơn
        const imgInput = document.getElementById('imgInput');
        const imgPreview = document.getElementById('imgPreview');

        imgInput.onchange = evt => {
            const [file] = imgInput.files;
            if (file) {
                imgPreview.src = URL.createObjectURL(file);
                imgPreview.classList.remove("d-none");
            } else {
                imgPreview.src = "#";
                imgPreview.classList.add("d-none");
            }
        };
    </script>
}