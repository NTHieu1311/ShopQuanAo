@model ShopQuanAo.Models.SanPham

@{
    ViewData["Title"] = "Xóa Sản Phẩm";
}

<div class="card shadow border-0 col-md-8 mx-auto mt-5 border-danger border-top border-4">
    <div class="card-body p-4">
        <div class="text-center mb-4">
            <i class="fas fa-exclamation-triangle fa-3x text-danger mb-3"></i>
            <h4 class="fw-bold">Bạn có chắc chắn muốn xóa sản phẩm này?</h4>
        </div>
        
        <div class="row bg-light p-3 rounded">
            <div class="col-md-4 text-center">
                @if (!string.IsNullOrEmpty(Model.HinhAnhChinh))
                {
                    <img src="@Model.HinhAnhChinh" class="img-fluid rounded shadow-sm" style="max-height: 150px;" />
                }
                else
                {
                    <div class="p-4 bg-secondary text-white rounded">Không có ảnh</div>
                }
            </div>
            <div class="col-md-8">
                <table class="table table-sm table-borderless">
                    <tr>
                        <th width="30%">Tên sản phẩm:</th>
                        <td class="fw-bold text-primary">@Model.TenSP</td>
                    </tr>
                    <tr>
                        <th>Danh mục:</th>
                        <td>@Model.DanhMuc.TenDM</td>
                    </tr>
                    <tr>
                        <th>Giá bán:</th>
                        <td class="text-danger fw-bold">@Model.GiaBan.ToString("#,##0") VNĐ</td>
                    </tr>
                </table>
            </div>
        </div>

        <div class="alert alert-warning mt-4 text-center">
            Hành động này sẽ xóa dữ liệu khỏi cơ sở dữ liệu và <strong>xóa luôn cả file ảnh</strong> trên máy chủ. Không thể hoàn tác!
        </div>

        <form asp-action="Delete" class="mt-4 text-center">
            <input type="hidden" asp-for="MaSP" />
            <a asp-action="Index" class="btn btn-secondary px-4 me-3">Hủy bỏ</a>
            <button type="submit" class="btn btn-danger px-4">
                <i class="fas fa-trash"></i> Xác nhận Xóa
            </button>
        </form>
    </div>
</div>