@model ShopQuanAo.Models.DanhMuc

@{
    ViewData["Title"] = "Xác Nhận Xóa";
}

<div class="card shadow border-0 col-md-6 mx-auto mt-5 border-danger border-top border-4">
    <div class="card-body text-center p-5">
        <i class="fas fa-exclamation-triangle fa-4x text-danger mb-4"></i>
        <h4 class="fw-bold">Bạn có chắc chắn muốn xóa?</h4>
        <p class="text-muted">Danh mục: <strong class="text-dark fs-5">@Model.TenDM</strong></p>
        
        <div class="alert alert-warning text-start mt-4" role="alert">
            <i class="fas fa-info-circle"></i> <strong>Cảnh báo:</strong> Việc xóa danh mục này có thể xóa luôn tất cả các sản phẩm thuộc danh mục này! Hành động này không thể hoàn tác.
        </div>

        <form asp-action="Delete" class="mt-4">
            <input type="hidden" asp-for="MaDM" />
            <a asp-action="Index" class="btn btn-secondary px-4 me-2">Hủy bỏ</a>
            <button type="submit" class="btn btn-danger px-4">
                <i class="fas fa-trash"></i> Xác nhận Xóa
            </button>
        </form>
    </div>
</div>