@model ShopQuanAo.Models.DanhMuc

@{
    ViewData["Title"] = "Chỉnh Sửa Danh Mục";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h4 class="fw-bold mb-0 text-primary"><i class="fas fa-edit me-2"></i>Chỉnh Sửa Danh Mục</h4>
        <div class="text-muted small mt-1">Đang chỉnh sửa: <strong class="text-dark">@Model.TenDM</strong></div>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 shadow-sm fw-medium">
        <i class="fas fa-arrow-left me-2"></i>Quay lại danh sách
    </a>
</div>

<div class="row justify-content-center">
    <div class="col-md-8 col-lg-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger d-none"></div>
            
            <input type="hidden" asp-for="MaDM" />

            <div class="main-card card border-0 mb-4">
                <div class="card-body p-4 p-md-5">
                    
                    <div class="mb-4">
                        <label asp-for="TenDM" class="form-label fw-bold">Tên danh mục <span class="text-danger">*</span></label>
                        <input asp-for="TenDM" class="form-control form-control-lg bg-light border-0" required autocomplete="off" />
                        <span asp-validation-for="TenDM" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="MoTa" class="form-label fw-bold">Mô tả ngắn</label>
                        <textarea asp-for="MoTa" class="form-control bg-light border-0" rows="4"></textarea>
                        <span asp-validation-for="MoTa" class="text-danger small mt-1 d-block"></span>
                    </div>

                    <div class="mb-5">
                        <label asp-for="TrangThai" class="form-label fw-bold">Trạng thái hiển thị</label>
                        <select asp-for="TrangThai" class="form-select bg-light border-0">
                            <option value="1">🟢 Hiển thị trên website</option>
                            <option value="0">🔴 Ẩn khỏi website</option>
                        </select>
                    </div>

                    <div class="d-flex justify-content-end align-items-center pt-3 border-top">
                        <a asp-action="Index" class="btn btn-light fw-bold px-4 me-3">Hủy bỏ</a>
                        <button type="submit" class="btn btn-primary px-5 py-2 fw-bold shadow-sm" style="border-radius: 8px;">
                            <i class="fas fa-save me-2"></i> Cập Nhật
                        </button>
                    </div>

                </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}