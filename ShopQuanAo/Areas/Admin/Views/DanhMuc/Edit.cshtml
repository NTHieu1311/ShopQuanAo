@model ShopQuanAo.Models.DanhMuc

@{
    ViewData["Title"] = "Chỉnh Sửa Danh Mục";
}

<div class="card shadow border-0 col-md-8 mx-auto mt-4">
    <div class="card-header bg-white py-3">
        <h6 class="m-0 font-weight-bold text-warning">Chỉnh Sửa Danh Mục: @Model.TenDM</h6>
    </div>
    <div class="card-body">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <input type="hidden" asp-for="MaDM" />

            <div class="mb-3">
                <label asp-for="TenDM" class="form-label fw-bold">Tên danh mục</label>
                <input asp-for="TenDM" class="form-control" required />
                <span asp-validation-for="TenDM" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="MoTa" class="form-label fw-bold">Mô tả</label>
                <textarea asp-for="MoTa" class="form-control" rows="3"></textarea>
                <span asp-validation-for="MoTa" class="text-danger"></span>
            </div>

            <div class="mb-4">
                <label asp-for="TrangThai" class="form-label fw-bold">Trạng thái</label>
                <select asp-for="TrangThai" class="form-select">
                    <option value="1">Hiển thị</option>
                    <option value="0">Ẩn</option>
                </select>
            </div>

            <div class="d-flex justify-content-between">
                <a asp-action="Index" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> Quay lại
                </a>
                <button type="submit" class="btn btn-warning text-dark fw-bold">
                    <i class="fas fa-save"></i> Cập nhật
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}