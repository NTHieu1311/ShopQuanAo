@model IEnumerable<ShopQuanAo.Models.DanhGia>
@{
    ViewData["Title"] = "Đánh giá của khách hàng";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show">
        <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card shadow border-0">
    <div class="card-header bg-white py-3">
        <h6 class="m-0 font-weight-bold text-primary">Quản lý Đánh giá</h6>
    </div>
    <div class="card-body">
        <table class="table table-bordered table-hover align-middle">
            <thead class="table-light">
                <tr>
                    <th width="15%">Sản phẩm</th>
                    <th width="15%">Khách hàng</th>
                    <th width="15%">Số sao</th>
                    <th width="30%">Nội dung</th>
                    <th width="10%">Trạng thái</th>
                    <th width="15%" class="text-center">Hành động</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold text-primary">@item.SanPham.TenSP</td>
                        <td>@item.TaiKhoan.TenDangNhap<br><small class="text-muted">@item.NgayDanhGia.ToString("dd/MM/yyyy")</small></td>
                        <td>
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (i <= item.DiemSao)
                                {
                                    <i class="fas fa-star text-warning"></i>
                                }
                                else
                                {

                                    <i class="far fa-star text-warning"></i>
                                }
                            }
                        </td>
                        <td>
                            @item.NoiDung
                            @if (!string.IsNullOrEmpty(item.HinhAnh))
                            {
                                <br>
                            
                                <img src="@item.HinhAnh" style="height: 40px; margin-top:5px; border-radius:4px;" />
                            }
                        </td>
                        <td>
                            @if (item.TrangThai == 1)
                            {
                                <span class="badge bg-success">Đang hiện</span>
                            }
                            else
                            {

                                <span class="badge bg-secondary">Đã ẩn</span>
                            }
                        </td>
                        <td class="text-center">
                            <a asp-action="Edit" asp-route-id="@item.MaDanhGia" class="btn btn-sm btn-warning" title="Duyệt/Ẩn"><i class="fas fa-eye-slash"></i></a>
                            <a asp-action="Delete" asp-route-id="@item.MaDanhGia" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
        @if (!Model.Any())
        {
            <div class="text-center text-muted mt-3">Chưa có đánh giá nào.</div>
        }
    </div>
</div>