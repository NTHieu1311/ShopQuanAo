@model ShopQuanAo.Models.DanhGia
@{
    ViewData["Title"] = "Xóa Đánh Giá";
}

<div class="row justify-content-center align-items-center" style="min-height: 60vh;">
    <div class="col-md-8 col-lg-6">
        
        <div class="main-card card border-0">
            <div class="card-body p-4 p-md-5">
                
                <div class="text-center mb-4">
                    <div class="d-inline-flex align-items-center justify-content-center bg-danger bg-opacity-10 rounded-circle mb-3" style="width: 80px; height: 80px;">
                        <i class="fas fa-trash-alt fa-2x text-danger"></i>
                    </div>
                    <h4 class="fw-bold text-dark">Xác nhận xóa đánh giá?</h4>
                    <p class="text-muted">Đánh giá này chứa nội dung vi phạm hoặc spam?</p>
                </div>
                
                <div class="bg-light p-4 rounded-4 mb-4 text-start border-start border-danger border-4">
                    <p class="mb-2"><strong class="text-muted">Khách hàng:</strong> <span class="fw-bold">@Model.TaiKhoan.TenDangNhap</span></p>
                    <p class="mb-2"><strong class="text-muted">Sản phẩm:</strong> <span class="text-primary fw-bold">@Model.SanPham.TenSP</span></p>
                    <p class="mb-0"><strong class="text-muted">Nội dung:</strong> <span class="fst-italic">"@Model.NoiDung"</span></p>
                </div>

                <div class="alert alert-warning border-0 bg-warning bg-opacity-10 text-dark p-3 rounded-3 mb-4 d-flex">
                    <i class="fas fa-info-circle text-warning mt-1 me-3 fa-lg"></i>
                    <div class="small">
                        <strong>Lưu ý:</strong> Hành động này sẽ xóa vĩnh viễn đánh giá khỏi cơ sở dữ liệu. Nếu bạn chỉ muốn tạm thời không cho khách khác thấy, hãy dùng chức năng <strong>Duyệt/Ẩn</strong> thay vì Xóa.
                    </div>
                </div>

                <form asp-action="Delete" class="d-flex justify-content-center align-items-center mt-4 border-top pt-4">
                    <input type="hidden" asp-for="MaDanhGia" />
                    
                    <a asp-action="Index" class="btn btn-light fw-bold px-4 me-3">Hủy bỏ</a>
                    <button type="submit" class="btn btn-danger px-5 py-2 fw-bold shadow-sm" style="border-radius: 8px;">
                        <i class="fas fa-trash-alt me-2"></i> Xác nhận Xóa
                    </button>
                </form>

            </div>
        </div>
    </div>
</div>