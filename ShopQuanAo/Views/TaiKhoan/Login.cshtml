@{
    ViewData["Title"] = "Đăng Nhập";
}

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-xl-10 col-lg-12">
            <div class="card border-0 shadow-lg rounded-4 overflow-hidden">
                <div class="row g-0">
                    <div class="col-lg-6 d-none d-lg-block" style="background: url('https://images.unsplash.com/photo-1441984904996-e0b6ba687e04?q=80&w=800&auto=format&fit=crop') center/cover;">
                        <div class="h-100 d-flex flex-column justify-content-center p-5" style="background: rgba(0,0,0,0.4);">
                            <h2 class="text-white fw-bold" style="font-family: 'Jost', sans-serif;">FASHION STORE</h2>
                            <p class="text-white-50">Định hình phong cách, dẫn đầu xu hướng. Đăng nhập ngay để nhận vô vàn ưu đãi độc quyền.</p>
                        </div>
                    </div>
                    
                    <div class="col-lg-6 p-4 p-md-5">
                        <div class="text-center mb-4">
                            <h2 class="fw-bold" style="font-family: 'Jost', sans-serif; color: #2f3542;">ĐĂNG NHẬP</h2>
                            <p class="text-muted">Chào mừng bạn quay lại với cửa hàng!</p>
                        </div>

                        @if (TempData["SuccessMessage"] != null)
                        {
                            <div class="alert alert-success alert-dismissible fade show rounded-3" role="alert">
                                <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }

                        @if (ViewBag.ErrorMessage != null)
                        {
                            <div class="alert alert-danger alert-dismissible fade show rounded-3" role="alert">
                                <i class="fas fa-exclamation-triangle me-2"></i> @ViewBag.ErrorMessage
                                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                            </div>
                        }

                        <form asp-action="Login" method="post">
                            <div class="form-floating mb-3">
                                <input type="text" class="form-control rounded-3 shadow-none" name="TenDangNhap" id="TenDangNhap" placeholder="Tên đăng nhập" required>
                                <label for="TenDangNhap" class="text-muted"><i class="fas fa-user me-2"></i>Tên đăng nhập</label>
                            </div>
                            
                            <div class="form-floating mb-4">
                                <input type="password" class="form-control rounded-3 shadow-none" name="MatKhau" id="MatKhau" placeholder="Mật khẩu" required>
                                <label for="MatKhau" class="text-muted"><i class="fas fa-lock me-2"></i>Mật khẩu</label>
                            </div>

                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <div class="form-check">
                                    <input class="form-check-input shadow-none" type="checkbox" value="" id="rememberMe">
                                    <label class="form-check-label text-muted" for="rememberMe">Ghi nhớ đăng nhập</label>
                                </div>
                                <a href="#" style="color: #ff4757; text-decoration: none; font-size: 0.9rem;">Quên mật khẩu?</a>
                            </div>

                            <button class="btn w-100 py-3 text-white fw-bold rounded-pill mb-4 shadow" style="background-color: #ff4757; font-size: 1.1rem; letter-spacing: 1px;" type="submit">ĐĂNG NHẬP</button>
                            
                            <div class="text-center mt-3">
                                <span class="text-muted">Bạn chưa có tài khoản?</span>
                                <a href="/TaiKhoan/Register" style="color: #ff4757; text-decoration: none; font-weight: 700;" class="ms-1">Đăng ký ngay</a>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>