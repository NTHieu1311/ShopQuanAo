@{
    ViewData["Title"] = "Đăng Ký Tài Khoản";
}

<div class="container mt-5 mb-5">
    <div class="row justify-content-center">
        <div class="col-md-7">
            <div class="card shadow border-0 rounded-lg">
                <div class="card-header bg-success text-white text-center py-4">
                    <h4 class="font-weight-light my-0"><i class="fas fa-user-plus"></i> ĐĂNG KÝ THÀNH VIÊN</h4>
                </div>
                <div class="card-body p-4">
                    @if (ViewBag.ErrorMessage != null)
                    {
                        <div class="alert alert-danger text-center">@ViewBag.ErrorMessage</div>
                    }

                    <form asp-action="Register" method="post">
                        <h6 class="text-muted border-bottom pb-2 mb-3">Thông tin đăng nhập</h6>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="form-floating mb-3 mb-md-0">
                                    <input class="form-control" name="TenDangNhap" type="text" placeholder="Tên đăng nhập" required />
                                    <label>Tên đăng nhập</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input class="form-control" name="MatKhau" type="password" placeholder="Mật khẩu" required />
                                    <label>Mật khẩu</label>
                                </div>
                            </div>
                        </div>

                        <h6 class="text-muted border-bottom pb-2 mb-3 mt-4">Thông tin cá nhân</h6>
                        <div class="form-floating mb-3">
                            <input class="form-control" name="HoTen" type="text" placeholder="Họ và Tên" required />
                            <label>Họ và Tên</label>
                        </div>
                        <div class="row mb-3">
                            <div class="col-md-6">
                                <div class="form-floating mb-3 mb-md-0">
                                    <input class="form-control" name="SoDienThoai" type="tel" placeholder="Số điện thoại" required />
                                    <label>Số điện thoại</label>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-floating">
                                    <input class="form-control" name="Email" type="email" placeholder="Email" required />
                                    <label>Email</label>
                                </div>
                            </div>
                        </div>
                        <div class="form-floating mb-3">
                            <input class="form-control" name="DiaChi" type="text" placeholder="Địa chỉ giao hàng" required />
                            <label>Địa chỉ nhận hàng</label>
                        </div>

                        <div class="mt-4 mb-0">
                            <button type="submit" class="btn btn-success w-100 py-2 fw-bold">TẠO TÀI KHOẢN</button>
                        </div>
                    </form>
                </div>
                <div class="card-footer text-center py-3">
                    <div class="small">Đã có tài khoản? <a asp-action="Login">Đi đến đăng nhập</a></div>
                </div>
            </div>
        </div>
    </div>
</div>