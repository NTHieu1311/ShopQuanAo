@{
    ViewData["Title"] = "Hệ Thống Cửa Hàng";
}

<style>
    .store-card {
        transition: all 0.3s ease;
        border-radius: 15px;
        border: 2px solid transparent;
        background-color: #fff;
        cursor: pointer;
    }
    
        .store-card:hover, .store-card.active {
            border-color: #ff4757;
            box-shadow: 0 10px 20px rgba(255, 71, 87, 0.1);
            transform: translateY(-5px);
        }
    
    .store-icon-wrap {
        width: 60px;
        height: 60px;
        background-color: #ffeaa7;
        color: #d63031;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.5rem;
    }
    
    .map-container {
        border-radius: 20px;
        overflow: hidden;
        box-shadow: 0 10px 30px rgba(0,0,0,0.1);
        height: 100%;
        min-height: 500px;
        position: sticky;
        top: 100px;
    }
</style>

<div class="container mt-5 mb-5">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-dark text-uppercase">Hệ Thống Cửa Hàng <span class="text-danger">FASHION STORE</span></h2>
        <p class="text-muted fs-5">Đến ngay chi nhánh gần nhất để trải nghiệm không gian mua sắm đẳng cấp!</p>
    </div>

    <div class="row g-4">
        <div class="col-lg-5">
            <h4 class="fw-bold mb-4 border-bottom pb-2"><i class="fas fa-map-marked-alt text-danger me-2"></i> Trụ Sở Chính & Các Chi Nhánh</h4>
            
            <div class="card store-card shadow-sm mb-4 p-3 active" onclick="changeMap('123 Đường Tôn Đức Thắng, Đống Đa, Hà Nội', this)">
                <div class="d-flex align-items-center mb-3">
                    <div class="store-icon-wrap me-3">
                        <i class="fas fa-store"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-1 text-danger">FASHION STORE - Hà Nội (Trụ sở chính)</h5>
                        <span class="badge bg-success">Đang mở cửa</span>
                    </div>
                </div>
                <p class="mb-2"><i class="fas fa-map-marker-alt text-muted me-2"></i> 123 Đường Tôn Đức Thắng, Q. Đống Đa, Hà Nội</p>
                <p class="mb-2"><i class="fas fa-phone-alt text-muted me-2"></i> 0909.123.456</p>
                <p class="mb-0"><i class="fas fa-clock text-muted me-2"></i> 08:00 AM - 10:00 PM</p>
            </div>

            <div class="card store-card shadow-sm mb-4 p-3" onclick="changeMap('Phố đi bộ Nguyễn Huệ, Hồ Chí Minh', this)">
                <div class="d-flex align-items-center mb-3">
                    <div class="store-icon-wrap me-3" style="background-color: #dff9fb; color: #22a6b3;">
                        <i class="fas fa-store-alt"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-1 text-info">FASHION STORE - TP. Hồ Chí Minh</h5>
                        <span class="badge bg-success">Đang mở cửa</span>
                    </div>
                </div>
                <p class="mb-2"><i class="fas fa-map-marker-alt text-muted me-2"></i> Phố đi bộ Nguyễn Huệ, Quận 1, TP. HCM</p>
                <p class="mb-2"><i class="fas fa-phone-alt text-muted me-2"></i> 0909.987.654</p>
                <p class="mb-0"><i class="fas fa-clock text-muted me-2"></i> 08:30 AM - 09:30 PM</p>
            </div>

            <div class="card store-card shadow-sm p-3" onclick="changeMap('Cầu Rồng, Đà Nẵng', this)">
                <div class="d-flex align-items-center mb-3">
                    <div class="store-icon-wrap me-3" style="background-color: #f1f2f6; color: #747d8c;">
                        <i class="fas fa-store-alt"></i>
                    </div>
                    <div>
                        <h5 class="fw-bold mb-1 text-secondary">FASHION STORE - Đà Nẵng</h5>
                        <span class="badge bg-secondary">Sắp khai trương</span>
                    </div>
                </div>
                <p class="mb-2"><i class="fas fa-map-marker-alt text-muted me-2"></i> Cầu Rồng, TP. Đà Nẵng</p>
                <p class="mb-2"><i class="fas fa-phone-alt text-muted me-2"></i> Hotline dự kiến: 1900.xxxx</p>
            </div>
        </div>

        <div class="col-lg-7">
            <div class="map-container">
                <iframe id="storeMap"
                        src=""
                        width="100%"
                        height="100%"
                        style="border:0;"
                        allowfullscreen=""
                        loading="lazy">
                </iframe>
            </div>
        </div>
    </div>
</div>

<script>
    function changeMap(address, element) {
        var mapUrl = "https://www.google.com/maps?q=" + encodeURIComponent(address) + "&output=embed";
        document.getElementById("storeMap").src = mapUrl;

        var cards = document.querySelectorAll('.store-card');
        cards.forEach(function(card) {
            card.classList.remove('active');
        });
        element.classList.add('active');
    }

    window.onload = function() {
        // Mặc định load địa chỉ Hà Nội giống trên hóa đơn
        changeMap("123 Đường Tôn Đức Thắng, Đống Đa, Hà Nội", document.querySelector('.store-card.active'));
    };
</script>