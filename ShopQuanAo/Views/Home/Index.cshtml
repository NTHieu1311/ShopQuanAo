@model IEnumerable<ShopQuanAo.Models.SanPham>
@{
    ViewData["Title"] = "Trang Chủ";
    var danhMucs = ViewBag.DanhMucs as IEnumerable<ShopQuanAo.Models.DanhMuc>;
}

<div id="heroCarousel" class="carousel slide mb-5 shadow-sm" data-bs-ride="carousel">
    <div class="carousel-indicators">
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="0" class="active"></button>
        <button type="button" data-bs-target="#heroCarousel" data-bs-slide-to="1"></button>
    </div>
    <div class="carousel-inner" style="border-radius: 0 0 30px 30px; overflow: hidden;">
        <div class="carousel-item active">
            <img src="https://images.unsplash.com/photo-1441984904996-e0b6ba687e04?ixlib=rb-4.0.3&auto=format&fit=crop&w=1600&q=80" class="d-block w-100" style="height: 500px; object-fit: cover;" alt="Banner 1">
            <div class="carousel-caption d-none d-md-block" style="background: rgba(0,0,0,0.5); padding: 20px; border-radius: 10px;">
                <h1 class="fw-bold text-white">BỘ SƯU TẬP MÙA HÈ 2026</h1>
                <p class="fs-5">Giảm giá lên đến 50% cho các mặt hàng áo thun và quần short.</p>
                <a href="#" class="btn btn-danger btn-lg rounded-pill px-4 fw-bold mt-2">MUA NGAY</a>
            </div>
        </div>
        <div class="carousel-item">
            <img src="https://images.unsplash.com/photo-1441986300917-64674bd600d8?q=80&w=1920&auto=format&fit=crop" class="d-block w-100" alt="Banner 2" style="height: 600px; object-fit: cover;">
            <div class="carousel-caption d-none d-md-block" style="background: rgba(0,0,0,0.5); padding: 20px; border-radius: 10px;">
                <h1 class="fw-bold text-white">PHONG CÁCH CÔNG SỞ LỊCH LÃM</h1>
                <p class="fs-5">Khám phá ngay bộ sưu tập áo sơ mi và quần âu mới nhất.</p>
                <a href="#" class="btn btn-light btn-lg text-dark rounded-pill px-4 fw-bold mt-2">XEM CHI TIẾT</a>
            </div>
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#heroCarousel" data-bs-slide="prev">
        <span class="carousel-control-prev-icon" aria-hidden="true"></span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#heroCarousel" data-bs-slide="next">
        <span class="carousel-control-next-icon" aria-hidden="true"></span>
    </button>
</div>

<div class="container">
    <div class="text-center mb-5">
        <h2 class="fw-bold text-dark text-uppercase position-relative d-inline-block">
            Danh Mục Nổi Bật
            <span style="position:absolute; bottom:-10px; left:25%; width:50%; height:3px; background-color:#ff4757;"></span>
        </h2>
    </div>
    
    <div class="row mb-5 text-center">
        @if (danhMucs != null)
        {
            foreach (var dm in danhMucs.Take(6))
            {
                <div class="col-4 col-md-2 mb-3">
                    <a href="/SanPham?category=@dm.TenDM" class="text-decoration-none text-dark">
                        <div class="bg-white rounded-circle shadow-sm mx-auto d-flex align-items-center justify-content-center" style="width: 100px; height: 100px; transition: 0.3s; border: 2px solid transparent;" onmouseover="this.style.borderColor='#ff4757'; this.style.transform='scale(1.1)';" onmouseout="this.style.borderColor='transparent'; this.style.transform='scale(1)';">
                            <i class="fas fa-tags fs-2 text-secondary"></i>
                        </div>
                        <h6 class="mt-3 fw-bold">@dm.TenDM</h6>
                    </a>
                </div>
            }
        }
    </div>

    <div class="d-flex justify-content-between align-items-end mb-4">
        <h2 class="fw-bold text-dark text-uppercase mb-0 position-relative d-inline-block">
            Sản Phẩm Mới Nhất
            <span style="position:absolute; bottom:-10px; left:0; width:50px; height:3px; background-color:#ff4757;"></span>
        </h2>
        <a href="/SanPham/Index" class="text-danger fw-bold text-decoration-none">Xem tất cả <i class="fas fa-arrow-right"></i></a>
    </div>

    <div class="row row-cols-1 row-cols-md-2 row-cols-lg-4 g-4 mb-5">
        @foreach (var sp in Model)
        {
            <div class="col">
                <div class="card h-100 border-0 shadow-sm" style="border-radius: 15px; overflow: hidden; transition: 0.3s;" onmouseover="this.classList.add('shadow-lg'); this.style.transform='translateY(-5px)';" onmouseout="this.classList.remove('shadow-lg'); this.style.transform='translateY(0)';">
                    
                    @if (sp.GiaGoc > sp.GiaBan)
                    {
                        int salePercent = (int)Math.Round((1 - (sp.GiaBan / sp.GiaGoc)) * 100);
                        <span class="position-absolute top-0 start-0 bg-danger text-white px-2 py-1 m-3 rounded fw-bold" style="z-index: 2; font-size: 0.8rem;">-@salePercent%</span>
                    }

                    <a href="/SanPham/Details/@sp.MaSP">
                        @{
                            // Xử lý ảnh lỗi
                            string hinhAnh = (!string.IsNullOrEmpty(sp.HinhAnhChinh) && (sp.HinhAnhChinh.StartsWith("/") || sp.HinhAnhChinh.StartsWith("http")))
                                             ? sp.HinhAnhChinh
                                             : "https://via.placeholder.com/300x400?text=S%E1%BA%A3n+Ph%E1%BA%A9m";
                        }
                        <img src="@hinhAnh" class="card-img-top" alt="@sp.TenSP" style="height: 300px; object-fit: cover;">
                    </a>
                    
                    <div class="card-body text-center d-flex flex-column">
                        <small class="text-muted text-uppercase mb-1">@sp.DanhMuc?.TenDM</small>
                        
                        <h6 class="card-title fw-bold text-dark mb-2">
                            <a href="/SanPham/Details/@sp.MaSP" class="text-decoration-none text-dark">@sp.TenSP</a>
                        </h6>
                        
                        <div class="mt-auto">
                            @if (sp.GiaGoc > sp.GiaBan)
                            {
                                <span class="text-muted text-decoration-line-through me-2">@sp.GiaGoc.ToString("#,##0") đ</span>
                            }
                            <span class="text-danger fw-bold fs-5">@sp.GiaBan.ToString("#,##0") đ</span>
                        </div>
                    </div>
                    
                    <div class="card-footer bg-white border-0 text-center pb-3 pt-0">
                        <a href="/SanPham/Details/@sp.MaSP" class="btn btn-outline-danger w-100 rounded-pill fw-bold">
                            <i class="fas fa-eye"></i> Xem chi tiết
                        </a>
                    </div>
                </div>
            </div>
        }
    </div>
    
    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="fas fa-box-open fa-3x text-muted mb-3"></i>
            <h5 class="text-muted">Hiện tại shop chưa có sản phẩm nào.</h5>
        </div>
    }
</div>