@{
    ViewData["Title"] = "Đặt hàng thành công";
}

<div class="container mt-5 mb-5 text-center">
    <div class="card border-0 shadow-lg rounded-4 mx-auto p-5" style="max-width: 600px;">
        <div class="mb-4">
            <i class="fas fa-check-circle text-success" style="font-size: 80px;"></i>
        </div>
        <h2 class="fw-bold text-dark mb-3">ĐẶT HÀNG THÀNH CÔNG!</h2>
        <p class="text-muted fs-5">Cảm ơn bạn đã tin tưởng và mua sắm tại FashionStore.</p>
        
        <div class="bg-light p-3 rounded-3 my-4">
            <p class="mb-1">Mã đơn hàng của bạn là:</p>
            <h3 class="fw-bold text-danger mb-0">#@ViewBag.MaDH</h3>
        </div>
        
        <p class="text-muted mb-4">Chúng tôi sẽ sớm liên hệ với bạn để xác nhận đơn hàng và tiến hành giao hàng. Vui lòng giữ điện thoại!</p>

        <div class="d-flex gap-3 justify-content-center mt-4">
            <a href="/" class="btn btn-outline-danger px-4 py-2 rounded-pill fw-bold"><i class="fas fa-home me-2"></i> Trở về trang chủ</a>
            <a href="/SanPham" class="btn btn-danger px-4 py-2 rounded-pill fw-bold">Tiếp tục mua sắm <i class="fas fa-shopping-bag ms-2"></i></a>
        </div>
    </div>
</div>